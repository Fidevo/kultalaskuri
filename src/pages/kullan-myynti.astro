---
import BaseLayout from '../layouts/BaseLayout.astro';
import FaqItem from '../components/FaqItem.astro';
import GoldCalculator from '../components/react/GoldCalculator.tsx';
import { getGoldPrice } from '../lib/api/metalPriceApi';
import { calculateGoldValue } from '../lib/calculations/goldCalculator';

// Reaaliaikainen kullan hinta
const goldPrice = await getGoldPrice();
const spot = goldPrice?.priceEurGram || 0;

// Reaaliaikaiset tavoitehinnat samalla logiikalla kuin etusivulla
const result24k = spot > 0 ? calculateGoldValue(1, '24K', spot) : null;
const result18k = spot > 0 ? calculateGoldValue(1, '18K', spot) : null;
const result14k = spot > 0 ? calculateGoldValue(1, '14K', spot) : null;

const p24k = result24k?.targetValue ?? 0;
const p18k = result18k?.targetValue ?? 0;
const p14k = result14k?.targetValue ?? 0;

const getTargetValue = (weight: number, purity: '14K' | '18K' | '24K') =>
  spot > 0 ? (calculateGoldValue(weight, purity, spot)?.targetValue ?? 0) : 0;

// Suomalainen desimaalimuoto (pilkku)
const fmt = (n: number) => n.toFixed(2).replace('.', ',');

const ex5g14k = getTargetValue(5, '14K');
const ex10g14k = getTargetValue(10, '14K');
const ex20g18k = getTargetValue(20, '18K');
const ex50g24k = getTargetValue(50, '24K');

const dateModified = new Date().toISOString();

const schemaData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://kultalaskuri.fi/#website",
      "url": "https://kultalaskuri.fi",
      "name": "Kultalaskuri.fi",
      "inLanguage": "fi-FI"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Kultalaskuri.fi",
          "item": "https://kultalaskuri.fi"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Kullan myynti",
          "item": "https://kultalaskuri.fi/kullan-myynti/"
        }
      ]
    },
    {
      "@type": "WebPage",
      "@id": "https://kultalaskuri.fi/kullan-myynti/",
      "url": "https://kultalaskuri.fi/kullan-myynti/",
      "name": "Kullan myynti – Paljonko kullasta saa rahaa?",
      "description": "Myy kulta fiksusti. Laske kullan arvo sekunneissa ja katso paljonko koruistasi voi saada. Vältä alihinnoittelu ja löydä paras hinta.",
      "inLanguage": "fi-FI",
      "dateModified": dateModified,
      "isPartOf": {
        "@id": "https://kultalaskuri.fi/#website"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Paljonko kullasta saa per gramma?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": `Kullasta maksettava hinta riippuu maailmanmarkkinahinnasta ja pitoisuudesta. Kullan reilu vähimmäistaso on juuri nyt noin ${fmt(p14k)} €/g 14 karaatin kullalle, ${fmt(p18k)} €/g 18 karaatin kullalle ja ${fmt(p24k)} €/g puhtaalle kullalle.`
          }
        },
        {
          "@type": "Question",
          "name": "Kannattaako kulta myydä nyt?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Kullan myynti voi olla kannattavaa silloin, kun markkinahinta on korkealla ja sinulla on tarpeettomia koruja tai muuta kultaa, jota et enää käytä. Ennen myyntiä kannattaa aina tarkistaa ajantasainen arvo laskurilla."
          }
        },
        {
          "@type": "Question",
          "name": "Mistä saa parhaan hinnan kullasta?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Parhaan hinnan saat yleensä vertailemalla useamman ostajan tarjouksia. Selvitä ensin kullan reilu vähimmäistaso, jotta tiedät, onko tarjous lähellä markkinatasoa."
          }
        },
        {
          "@type": "Question",
          "name": "Miten kullan hinta määräytyy?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Kullan hinta määräytyy globaaleilla rahoitusmarkkinoilla kysynnän ja tarjonnan mukaan. Lopulliseen ostohintaan vaikuttavat lisäksi kullan pitoisuus, paino sekä ostajan oma marginaali."
          }
        },
        {
          "@type": "Question",
          "name": "Mitä pitää ottaa mukaan kullan myyntitilanteeseen?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ota mukaan voimassa oleva henkilöllisyystodistus (passi tai ajokortti) — se on pakollinen kaikissa kullan ostoissa Suomessa rahanpesun estämiseksi. Ota lisäksi mukaan myytävät esineet ja kannattaa ottaa kuva tai tuloste Kultalaskuri.fi-laskurin antamasta vähimmäistasosta vertailun tueksi."
          }
        },
        {
          "@type": "Question",
          "name": "Voiko rikkinäistä tai vaurioitunutta kultaa myydä?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Kyllä. Rikkinäiset korut, irronneet osat, kuluneet sormukset ja parittomiksi jääneet korvakorut käyvät kaikki kaupaksi. Kullanostajat maksavat kultapitoisuuden ja painon perusteella, ei esineen kunnon mukaan. Rikkinäinen kultakoru on yhtä arvokas raaka-aineena kuin ehjäkin."
          }
        },
        {
          "@type": "Question",
          "name": "Mitä perintökullalle kannattaa tehdä?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Perintökoruja myydessä kannattaa ensin selvittää, onko kyseessä nimikkokorusuunnittelijan tai arvostetun merkin teos. Kalevala-korut, Lapponian mallistot tai tunnettujen kultaseppien erikoistyöt voivat olla paljon arvokkaampia ehjinä kappaleina kuin pelkkänä kultana. Tarkista korun käypä hintataso kauppapaikka-alustojen ilmoituksista ja päättyneistä huutokaupoista ennen myyntiä kullanostajalle."
          }
        },
        {
          "@type": "Question",
          "name": "Miten ja milloin kullasta maksetaan?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Maksutapa ja aikataulu vaihtelevat ostajittain. Paikallisissa liikkeissä maksu tapahtuu usein heti käynnin yhteydessä, kun taas verkkopalvelut ja postitse toimivat ostajat maksavat yleensä tilisiirtona 1–3 arkipäivässä lähetyksen arvioinnin jälkeen. Varmista maksutapa ja aikataulu aina etukäteen suoraan ostajalta."
          }
        },
        {
          "@type": "Question",
          "name": "Miten kilpailuttaa kullanostajia?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Laske ensin kullan reilu vähimmäistaso ilmaisella kultalaskurilla, jotta tiedät tavoitteesi. Sen jälkeen pyydä tarjous vähintään kahdesta tai kolmesta eri liikkeestä tai verkkopalvelusta. Kerro avoimesti, että kilpailutat tarjouksia — usein ostaja on halukas parantamaan hintaa, jos hän tietää sinulla olevan muitakin vaihtoehtoja."
          }
        }
      ]
    }
  ]
};

const faqItems = (schemaData["@graph"].find((n: any) => n["@type"] === "FAQPage") as any)?.mainEntity ?? [];
---

<BaseLayout 
  title="Kullan myynti – Paljonko kullasta saa rahaa? | Kultalaskuri.fi" 
  description="Myy kulta fiksusti. Laske kullan arvo sekunneissa ja katso paljonko koruistasi voi saada. Vältä alihinnoittelu ja löydä paras hinta."
  schema={JSON.stringify(schemaData)}
>

  <div class="relative bg-[#0B0F19] pt-28 pb-40 px-4 overflow-hidden">

    {/* Blob-taustaefektit (kevyt CSS-only) */}
    <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
      <div class="absolute top-0 right-1/4 w-96 h-96 bg-gold-400/15 rounded-full mix-blend-screen filter blur-[120px] animate-blob"></div>
      <div class="absolute top-20 left-1/4 w-80 h-80 bg-blue-600/15 rounded-full mix-blend-screen filter blur-[100px] animate-blob animation-delay-2000"></div>
    </div>

    <div class="max-w-4xl mx-auto text-center relative z-10">

      <nav aria-label="Murupolku" class="mb-6">
        <ol class="flex items-center justify-center gap-2 text-xs text-gray-500">
          <li><a href="/" class="hover:text-gold-400 transition-colors">Etusivu</a></li>
          <li aria-hidden="true">›</li>
          <li aria-current="page" class="text-gray-400">Kullan myynti</li>
        </ol>
      </nav>

      {/* Live-hintabadge */}
      <div class="inline-flex items-center gap-2.5 px-4 py-2 rounded-full bg-white/10 border border-white/10 backdrop-blur-md shadow-lg mb-8">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
        </span>
        <span class="text-xs text-gray-400 uppercase tracking-widest font-medium">Kullan hinta nyt:</span>
        <span class="text-white font-bold text-sm tabular-nums">
          {spot > 0 ? `${fmt(spot)} €/g` : '–'}
        </span>
        <span class="text-gray-400 text-xs">(24K)</span>
      </div>

      <h1 class="text-3xl md:text-5xl font-black text-white mb-4 leading-tight tracking-tight">
        Kullan myynti –
        <span class="block text-transparent bg-clip-text bg-gradient-to-r from-gold-200 to-gold-600 mt-1">
          näin saat parhaan hinnan kullastasi
        </span>
      </h1>
      <p class="text-sm md:text-base text-gray-400 max-w-2xl mx-auto leading-relaxed mb-10">
        Selvitä kullan arvo sekunneissa ja vältä alihinnoittelu. Katso mitä koruistasi oikeasti kannattaa pyytää.
      </p>

      <a href="#myyntilaskuri" class="inline-flex items-center justify-center gap-2 bg-gold-500 text-[#0B0F19] px-8 py-4 rounded-xl font-bold hover:bg-white hover:scale-105 transition-all duration-300 shadow-xl whitespace-nowrap">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="20" x="4" y="2" rx="2"></rect><line x1="8" x2="16" y1="6" y2="6"></line><line x1="16" x2="16" y1="14" y2="18"></line><path d="M16 10h.01"></path><path d="M12 10h.01"></path><path d="M8 10h.01"></path><path d="M12 14h.01"></path><path d="M8 14h.01"></path><path d="M12 18h.01"></path><path d="M8 18h.01"></path></svg>
        Laske kullan arvo ↓
      </a>
    </div>
  </div>

  <div id="myyntilaskuri" class="max-w-5xl mx-auto -mt-20 relative z-30 px-4 mb-24">
    <div class="bg-white rounded-3xl shadow-2xl border border-gray-100 p-2 md:p-6">
      <div class="text-center mb-4 px-4 pt-4">
        <p class="text-sm text-gray-500">Syötä korun paino ja pitoisuus – näet heti reilun vähimmäistason euroissa päivän kurssin perusteella.</p>
      </div>

      {goldPrice ? (
        <GoldCalculator client:visible spotPriceEurPerGram={goldPrice.priceEurGram} />
      ) : (
        <div class="text-center p-12">
          <p class="text-red-500 font-bold">Hintatietoja ei saatavilla juuri nyt.</p>
        </div>
      )}
    </div>
  </div>

  <section class="bg-white py-12 px-4 relative z-20">
    <div class="max-w-3xl mx-auto">

      {/* Sisällysluettelo — nopea navigointi pitkällä opassivulla */}
      <nav aria-label="Sisällysluettelo" class="mb-12 p-6 bg-gray-50 rounded-2xl border border-gray-200">
        <h2 class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-4">Tällä sivulla</h2>
        <ol class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-2 text-sm">
          <li><a href="#paljonko-saa" class="text-gold-600 font-bold hover:underline">Paljonko kullasta saa rahaa?</a></li>
          <li><a href="#nain-toimii" class="text-gold-600 font-bold hover:underline">Näin myynti toimii käytännössä</a></li>
          <li><a href="#missa-myyda" class="text-gold-600 font-bold hover:underline">Missä kulta kannattaa myydä?</a></li>
          <li><a href="#myyntitilanne" class="text-gold-600 font-bold hover:underline">Mitä myyntitilanteessa tapahtuu?</a></li>
          <li><a href="#virheet" class="text-gold-600 font-bold hover:underline">Yleisimmät virheet</a></li>
          <li><a href="#ukk" class="text-gold-600 font-bold hover:underline">Usein kysyttyä</a></li>
        </ol>
      </nav>

      <h2 id="paljonko-saa" class="text-3xl md:text-4xl font-black text-gray-900 mb-6 tracking-tight scroll-mt-24">Paljonko kullasta saa rahaa?</h2>
      <p class="text-lg text-gray-600 leading-relaxed mb-6">
        Kullan myyntihinta perustuu maailmanmarkkinoiden spot-hintaan eli puhtaan 24 karaatin kullan pörssihintaan. Lopullinen arvio riippuu kullan pitoisuudesta, painosta ja ostajan käyttämästä marginaalista.
      </p>
      <div class="bg-gray-50 rounded-2xl p-6 border border-gray-200 mb-8 shadow-sm">
        <ul class="space-y-4 text-gray-700 font-medium">
          <li class="flex justify-between items-center gap-4 border-b border-gray-200 pb-3 hover:bg-gray-100 transition-colors p-2 rounded-lg">
            <span><strong>585 (14K)</strong> – Suomen yleisin korukulta</span>
            <span class="text-gold-600 font-bold whitespace-nowrap shrink-0">~{fmt(p14k)} €/g</span>
          </li>
          <li class="flex justify-between items-center gap-4 border-b border-gray-200 pb-3 hover:bg-gray-100 transition-colors p-2 rounded-lg">
            <span><strong>750 (18K)</strong> – Arvokorut</span>
            <span class="text-gold-600 font-bold whitespace-nowrap shrink-0">~{fmt(p18k)} €/g</span>
          </li>
          <li class="flex justify-between items-center gap-4 pb-1 hover:bg-gray-100 transition-colors p-2 rounded-lg">
            <span><strong>999 (24K)</strong> – Kultaharkot</span>
            <span class="text-gold-600 font-bold whitespace-nowrap shrink-0">~{fmt(p24k)} €/g</span>
          </li>
        </ul>
      </div>
      <div class="bg-white border border-gray-200 rounded-2xl p-6 mb-16 shadow-sm">
        <h3 class="text-2xl font-black text-gray-900 mb-4 tracking-tight">Esimerkkejä: paljonko kullasta saa käytännössä?</h3>
        <p class="text-gray-600 leading-relaxed mb-6">
          Tyypillisiä myyntieriä päivän kurssilla laskettuna — älä myy näitä halvemmalla:
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="p-4 rounded-xl bg-gray-50 border border-gray-100">
            <div class="text-sm text-gray-500 mb-1">5 g 14K (585)</div>
            <div class="text-xl font-black text-gray-900">{fmt(ex5g14k)} €</div>
          </div>
          <div class="p-4 rounded-xl bg-gray-50 border border-gray-100">
            <div class="text-sm text-gray-500 mb-1">10 g 14K (585)</div>
            <div class="text-xl font-black text-gray-900">{fmt(ex10g14k)} €</div>
          </div>
          <div class="p-4 rounded-xl bg-gray-50 border border-gray-100">
            <div class="text-sm text-gray-500 mb-1">20 g 18K (750)</div>
            <div class="text-xl font-black text-gray-900">{fmt(ex20g18k)} €</div>
          </div>
          <div class="p-4 rounded-xl bg-gray-50 border border-gray-100">
            <div class="text-sm text-gray-500 mb-1">50 g 24K (999)</div>
            <div class="text-xl font-black text-gray-900">{fmt(ex50g24k)} €</div>
          </div>
        </div>

        <div class="mt-6">
          <a href="#myyntilaskuri" class="text-gold-600 font-bold hover:underline inline-flex items-center gap-1">
            Laske oma tarkka arvo laskurilla <span>&rarr;</span>
          </a>
        </div>
      </div>

      <h2 id="nain-toimii" class="text-3xl md:text-4xl font-black text-gray-900 mb-8 tracking-tight scroll-mt-24">Näin kullan myynti toimii käytännössä</h2>
      <div class="space-y-6 mb-16">
        <div class="flex gap-4 p-4 rounded-xl hover:bg-gray-50 transition-colors border border-transparent hover:border-gray-100">
          <div class="w-12 h-12 rounded-full bg-gold-100 text-gold-700 font-black flex items-center justify-center shrink-0 shadow-sm text-xl">1</div>
          <div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">Punnitse ja tarkista leima</h3>
            <p class="text-gray-600">Punnitse korut esimerkiksi tarkalla keittiövaa’alla ja etsi <a href="/kullan-leimat/" class="text-gold-600 font-bold hover:underline">kullan leimat</a>, kuten 585 tai 750.</p>
          </div>
        </div>
        <div class="flex gap-4 p-4 rounded-xl hover:bg-gray-50 transition-colors border border-transparent hover:border-gray-100">
          <div class="w-12 h-12 rounded-full bg-gold-100 text-gold-700 font-black flex items-center justify-center shrink-0 shadow-sm text-xl">2</div>
          <div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">Laske arvo etukäteen</h3>
            <p class="text-gray-600">Syötä paino ja karaatit sivun yläosan <a href="#myyntilaskuri" class="text-gold-600 font-bold hover:underline">laskuriin</a>. Näet heti summan, jota myyntitilanteessa kannattaa tavoitella.</p>
          </div>
        </div>
        <div class="flex gap-4 p-4 rounded-xl hover:bg-gray-50 transition-colors border border-transparent hover:border-gray-100">
          <div class="w-12 h-12 rounded-full bg-gold-100 text-gold-700 font-black flex items-center justify-center shrink-0 shadow-sm text-xl">3</div>
          <div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">Pyydä tarjous useammalta ostajalta</h3>
            <p class="text-gray-600">Voit myydä kullan paikallisessa liikkeessä tai postituspalvelun kautta. Vertaile tarjousta laskurin antamaan vähimmäistasoon ennen päätöstä.</p>
          </div>
        </div>
      </div>

      <h2 id="missa-myyda" class="text-3xl md:text-4xl font-black text-gray-900 mb-6 tracking-tight scroll-mt-24">Missä kulta kannattaa myydä?</h2>
      <p class="text-lg text-gray-600 leading-relaxed mb-6">
        Kultaa myydään tavallisesti joko paikalliselle kullanostajalle tai verkkopalvelulle, joka ottaa lähetyksiä vastaan postitse. Molemmissa vaihtoehdoissa on omat etunsa.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-10">
        <div class="p-6 bg-gray-50 rounded-2xl border border-gray-200">
          <h3 class="text-xl font-bold text-gray-900 mb-3">Paikallinen liike</h3>
          <ul class="space-y-2 text-gray-600 text-sm leading-relaxed">
            <li>+ Saat usein arvion ja rahat nopeasti</li>
            <li>+ Voit asioida kasvotusten</li>
            <li>– Hinta ei aina ole markkinan korkein</li>
          </ul>
        </div>
        <div class="p-6 bg-gray-50 rounded-2xl border border-gray-200">
          <h3 class="text-xl font-bold text-gray-900 mb-3">Verkkopalvelu ja postitus</h3>
          <ul class="space-y-2 text-gray-600 text-sm leading-relaxed">
            <li>+ Kilpailukykyinen hinta on usein mahdollinen</li>
            <li>+ Helppo kilpailuttaa useampia toimijoita</li>
            <li>– Prosessi kestää yleensä pidempään</li>
          </ul>
        </div>
      </div>

      <p class="text-gray-600 leading-relaxed mb-6">
        Paras ratkaisu riippuu siitä, arvostatko enemmän nopeutta vai mahdollisimman korkeaa tarjousta. Ennen myyntiä tärkeintä on tietää oma tavoitehintasi, jotta pystyt vertaamaan tarjouksia järkevästi.
      </p>

      <div class="mb-16">
        <a href="#myyntilaskuri" class="text-gold-600 font-bold hover:underline inline-flex items-center gap-1">
          Tarkista kullan arvo ennen myyntiä <span>&rarr;</span>
        </a>
      </div>

      <h2 id="myyntitilanne" class="text-3xl md:text-4xl font-black text-gray-900 mb-6 tracking-tight scroll-mt-24">Mitä myyntitilanteessa tapahtuu käytännössä?</h2>
      <p class="text-lg text-gray-600 leading-relaxed mb-6">
        Ensimmäistä kertaa kultaa myyvä ei aina tiedä, mitä odottaa. Tässä tyypillinen kullan myyntikäynti askel askeleelta.
      </p>
      <div class="space-y-4 mb-6">
        <div class="flex gap-4 p-4 bg-gray-50 rounded-xl border border-gray-100">
          <div class="w-9 h-9 rounded-full bg-gold-100 text-gold-700 font-black flex items-center justify-center shrink-0 text-sm">1</div>
          <div>
            <h3 class="font-bold text-gray-900 mb-1">Tuo henkilöllisyystodistus</h3>
            <p class="text-sm text-gray-600">Passi tai ajokortti on lain mukaan pakollinen jokaisessa kullan myyntitilanteessa. Ilman sitä kauppaa ei synny.</p>
          </div>
        </div>
        <div class="flex gap-4 p-4 bg-gray-50 rounded-xl border border-gray-100">
          <div class="w-9 h-9 rounded-full bg-gold-100 text-gold-700 font-black flex items-center justify-center shrink-0 text-sm">2</div>
          <div>
            <h3 class="font-bold text-gray-900 mb-1">Kulta punnitaan silmiesi edessä</h3>
            <p class="text-sm text-gray-600">Ostaja punnitsee jokaisen esineen tarkalla vaa'alla. Voit seurata punnitusta — se on normaali käytäntö, ei epäluottamuksen merkki.</p>
          </div>
        </div>
        <div class="flex gap-4 p-4 bg-gray-50 rounded-xl border border-gray-100">
          <div class="w-9 h-9 rounded-full bg-gold-100 text-gold-700 font-black flex items-center justify-center shrink-0 text-sm">3</div>
          <div>
            <h3 class="font-bold text-gray-900 mb-1">Saat tarjouksen heti paikalla</h3>
            <p class="text-sm text-gray-600">Tarjous annetaan yleensä saman tien. Sinulla on oikeus miettiä ja kieltäytyä — mikään ei pakota hyväksymään ensimmäistä tarjousta.</p>
          </div>
        </div>
        <div class="flex gap-4 p-4 bg-gray-50 rounded-xl border border-gray-100">
          <div class="w-9 h-9 rounded-full bg-gold-100 text-gold-700 font-black flex items-center justify-center shrink-0 text-sm">4</div>
          <div>
            <h3 class="font-bold text-gray-900 mb-1">Saat maksun sovitulla tavalla</h3>
            <p class="text-sm text-gray-600">Maksutapa ja aikataulu vaihtelevat ostajittain: paikallisissa liikkeissä maksu tapahtuu usein heti käynnin yhteydessä, postitse toimivat palvelut maksavat tilisiirtona 1–3 arkipäivässä. Varmista käytäntö etukäteen.</p>
          </div>
        </div>
      </div>
      <p class="text-sm text-gray-500 mb-16 p-4 bg-blue-50/50 rounded-xl border border-blue-100">
        <strong>Vinkki:</strong> Ota mukaan kuva tai tuloste laskurin antamasta vähimmäistasosta. Se toimii neuvotteluvalttina, kun vertailet tarjouksia.
      </p>

      <h2 id="virheet" class="text-3xl md:text-4xl font-black text-gray-900 mb-6 tracking-tight scroll-mt-24">Yleisimmät virheet kullan myynnissä</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-20">
        <div class="p-6 bg-red-50/50 hover:bg-red-50 border border-red-100 rounded-2xl transition-colors">
          <div class="w-8 h-8 rounded-full bg-red-100 text-red-600 flex items-center justify-center font-bold mb-3">1</div>
          <strong class="text-red-900 block mb-2 text-lg">Myyt ilman hintatietoa</strong>
          <span class="text-red-800/80 text-sm leading-relaxed block">Jos et tiedä kultasi arvoa, et tiedä onko saamasi tarjous reilu. Tarkista arvo aina ensin.</span>
        </div>
        
        <div class="p-6 bg-red-50/50 hover:bg-red-50 border border-red-100 rounded-2xl transition-colors">
          <div class="w-8 h-8 rounded-full bg-red-100 text-red-600 flex items-center justify-center font-bold mb-3">2</div>
          <strong class="text-red-900 block mb-2 text-lg">Hyväksyt ensimmäisen tarjouksen</strong>
          <span class="text-red-800/80 text-sm leading-relaxed block">Eri ostajien hinnoissa voi olla selviä eroja. Jos mahdollista, vertaile useampi tarjous ennen päätöstä.</span>
        </div>
        
        <div class="p-6 bg-red-50/50 hover:bg-red-50 border border-red-100 rounded-2xl transition-colors">
           <div class="w-8 h-8 rounded-full bg-red-100 text-red-600 flex items-center justify-center font-bold mb-3">3</div>
          <strong class="text-red-900 block mb-2 text-lg">Et tarkista leimoja</strong>
          <span class="text-red-800/80 text-sm leading-relaxed block">18K kulta on arvokkaampaa kuin 14K. Varmista aina, että pitoisuus on tiedossa ennen myyntiä.</span>
        </div>
        
        <div class="p-6 bg-red-50/50 hover:bg-red-50 border border-red-100 rounded-2xl transition-colors">
           <div class="w-8 h-8 rounded-full bg-red-100 text-red-600 flex items-center justify-center font-bold mb-3">4</div>
          <strong class="text-red-900 block mb-2 text-lg">Myyt design-korun romuna</strong>
          <span class="text-red-800/80 text-sm leading-relaxed block">Tunnettujen merkkien (kuten Kalevala, Lapponia tai Tapio Wirkkala) design-koruilla on usein huomattavasti enemmän arvoa ehjänä esineenä kuin pelkkänä sulatettavana kultana. Tarkista korujen brändi ennen myyntiä.</span>
        </div>
      </div>

      {/* Verotus-nosto — linkki syventävälle sivulle */}
      <div class="mb-16 p-6 bg-gold-50/50 border border-gold-200 rounded-2xl">
        <h2 class="text-xl font-black text-gray-900 mb-2">Muista verotus, jos myyt suuremman erän</h2>
        <p class="text-gray-600 text-sm leading-relaxed mb-3">
          Tavanomaisen koti-irtaimiston, kuten omien korujen, myynti on verovapaata 5 000 euroon asti vuodessa.
          Suuremmissa erissä ja sijoituskullassa luovutusvoitto voi olla veronalaista tuloa.
        </p>
        <a href="/kullan-myynti-verotus/" class="text-gold-600 font-bold hover:underline inline-flex items-center gap-1">
          Lue opas: kullan myynti ja verotus <span>&rarr;</span>
        </a>
      </div>

      <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-8 tracking-tight">Usein kysyttyä kullan myynnistä</h2>
      <div id="ukk" class="grid grid-cols-1 gap-4 mb-16">
        {faqItems.map((item: any) => (
          <FaqItem question={item.name} answer={item.acceptedAnswer.text} />
        ))}
      </div>

    </div>
  </section>


