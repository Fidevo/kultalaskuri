---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getGoldPrice } from '../lib/api/metalPriceApi';
import { calculateGoldValue } from '../lib/calculations/goldCalculator';

const goldPrice = await getGoldPrice();
const spot = goldPrice?.priceEurGram || 0;
const p14k = spot > 0 ? (calculateGoldValue(1, '14K', spot)?.targetValue ?? 0) : 0;
const p18k = spot > 0 ? (calculateGoldValue(1, '18K', spot)?.targetValue ?? 0) : 0;
const fmt = (n: number) => n.toFixed(2).replace('.', ',');
// Suomen aikavyöhyke eksplisiittisesti — build ajetaan UTC-palvelimella
const updatedDate = (goldPrice?.updatedAt ?? new Date()).toLocaleDateString('fi-FI', { timeZone: 'Europe/Helsinki' });

const embedCode = `<div id="kultalaskuri-widget"></div>
<script async src="https://kultalaskuri.fi/widget.js"><\/script>`;

const schemaData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://kultalaskuri.fi/#website",
      "url": "https://kultalaskuri.fi",
      "name": "Kultalaskuri.fi",
      "inLanguage": "fi-FI"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Kultalaskuri.fi", "item": "https://kultalaskuri.fi" },
        { "@type": "ListItem", "position": 2, "name": "Hintawidget", "item": "https://kultalaskuri.fi/widget/" }
      ]
    },
    {
      "@type": "WebPage",
      "@id": "https://kultalaskuri.fi/widget/",
      "url": "https://kultalaskuri.fi/widget/",
      "name": "Ilmainen kullan hinta -widget sivullesi",
      "description": "Upota päivittyvä kullan hinta omalle sivustollesi ilmaiseksi. Kevyt widget näyttää spot-hinnan ja tavoitehintatasot — asennus yhdellä koodirivillä.",
      "inLanguage": "fi-FI",
      "isPartOf": { "@id": "https://kultalaskuri.fi/#website" }
    }
  ]
};
---

<BaseLayout
  title="Ilmainen kullan hinta -widget sivullesi | Kultalaskuri.fi"
  description="Upota päivittyvä kullan hinta omalle sivustollesi ilmaiseksi. Kevyt widget näyttää spot-hinnan ja tavoitehintatasot — asennus yhdellä koodirivillä."
  schema={JSON.stringify(schemaData)}
>

  <div class="relative bg-[#0B0F19] pt-28 pb-20 px-4 overflow-hidden">
    <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
      <div class="absolute top-0 left-1/3 w-96 h-96 bg-gold-400/15 rounded-full mix-blend-screen filter blur-[120px] animate-blob"></div>
    </div>

    <div class="max-w-3xl mx-auto relative z-10 text-center">
      <nav aria-label="Murupolku" class="mb-6">
        <ol class="flex items-center justify-center gap-2 text-xs text-gray-500">
          <li><a href="/" class="hover:text-gold-400 transition-colors">Etusivu</a></li>
          <li aria-hidden="true">›</li>
          <li aria-current="page" class="text-gray-400">Hintawidget</li>
        </ol>
      </nav>

      <h1 class="text-3xl md:text-5xl font-black text-white mb-4 leading-tight tracking-tight">
        Kullan hinta
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-gold-200 to-gold-600">omalle sivullesi</span>
      </h1>
      <p class="text-sm md:text-base text-gray-400 leading-relaxed max-w-2xl mx-auto">
        Ilmainen, kevyt widget, joka näyttää päivittyvän kullan hinnan sivustollasi.
        Asennus vie alle minuutin — yksi div ja yksi script-rivi.
      </p>
    </div>
  </div>

  <section class="bg-white py-16 px-4">
    <div class="max-w-3xl mx-auto">

      <div class="grid md:grid-cols-2 gap-10 items-start mb-16">

        <div class="min-w-0">
          <h2 class="text-2xl font-black text-gray-900 mb-4 tracking-tight">Miltä widget näyttää</h2>
          <p class="text-gray-600 text-sm leading-relaxed mb-6">
            Widget hakee hinnan automaattisesti kerran päivässä päivittyvästä datastamme.
            Se ei käytä evästeitä eikä seuraa kävijöitäsi.
          </p>

          {/* Staattinen esikatselu — sama ulkoasu kuin widget.js tuottaa */}
          <div class="max-w-[320px] bg-[#0B0F19] border border-gold-400/30 rounded-[14px] px-[18px] py-4" aria-label="Widgetin esikatselu">
            <div class="flex justify-between items-center mb-2.5">
              <span class="text-[11px] font-bold tracking-[0.1em] uppercase text-gray-400">Kullan hinta</span>
              <span class="text-[10px] text-gray-500">{updatedDate}</span>
            </div>
            <div class="text-[28px] font-extrabold text-white leading-none mb-0.5 tabular-nums">
              {spot > 0 ? fmt(spot) : '–'} <span class="text-sm text-gold-400">€/g</span>
            </div>
            <div class="text-[10px] text-gray-500 mb-3">24K spot-hinta</div>
            <div class="mb-3">
              <div class="flex justify-between items-baseline py-1.5 border-b border-white/10">
                <span class="text-xs text-gray-400">585 (14K) tavoitehinta</span>
                <span class="text-sm font-bold text-gold-400 tabular-nums">{fmt(p14k)} €/g</span>
              </div>
              <div class="flex justify-between items-baseline py-1.5 border-b border-white/10">
                <span class="text-xs text-gray-400">750 (18K) tavoitehinta</span>
                <span class="text-sm font-bold text-white tabular-nums">{fmt(p18k)} €/g</span>
              </div>
            </div>
            <span class="block text-center text-xs font-bold text-[#0B0F19] bg-gold-400 rounded-lg px-2.5 py-2">Laske kultasi arvo →</span>
            <div class="text-center mt-2"><span class="text-[10px] text-gray-500">Lähde: Kultalaskuri.fi</span></div>
          </div>
        </div>

        <div class="min-w-0">
          <h2 class="text-2xl font-black text-gray-900 mb-4 tracking-tight">Asennus</h2>
          <p class="text-gray-600 text-sm leading-relaxed mb-4">
            Kopioi alla oleva koodi sivullesi siihen kohtaan, jossa haluat widgetin näkyvän:
          </p>

          <pre class="bg-[#0B0F19] text-gray-200 text-xs leading-relaxed rounded-2xl p-5 overflow-x-auto mb-4"><code>{embedCode}</code></pre>

          <button
            id="copy-embed"
            type="button"
            class="inline-flex items-center gap-2 bg-gold-500 text-[#0B0F19] px-5 py-2.5 rounded-xl font-bold text-sm hover:bg-gold-400 transition-colors"
            data-code={embedCode}
          >
            Kopioi koodi
          </button>

          <div class="mt-8 space-y-3 text-sm text-gray-600">
            <div class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-green-100 text-green-600 flex items-center justify-center shrink-0 mt-0.5">✓</span>
              <span><strong>Ilmainen</strong> — ainoa ehto on, että "Lähde: Kultalaskuri.fi" -linkki säilyy näkyvissä.</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-green-100 text-green-600 flex items-center justify-center shrink-0 mt-0.5">✓</span>
              <span><strong>Kevyt</strong> — noin 2 kt JavaScriptiä, ei ulkoisia kirjastoja, ei evästeitä.</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-green-100 text-green-600 flex items-center justify-center shrink-0 mt-0.5">✓</span>
              <span><strong>Turvallinen</strong> — jos hintadata ei ole saatavilla, widget ei riko sivuasi.</span>
            </div>
          </div>
        </div>
      </div>

      <h2 class="text-2xl font-black text-gray-900 mb-4 tracking-tight">Avoin data kehittäjille</h2>
      <p class="text-gray-600 leading-relaxed mb-4">
        Sama data on saatavilla suoraan JSON-muodossa osoitteesta
        <a href="/hinta.json" class="text-gold-600 font-bold hover:underline font-mono text-sm">kultalaskuri.fi/hinta.json</a>.
        Vastaus sisältää 24K-spot-hinnan sekä 14K/18K/24K-tavoitehintatasot euroina grammalta.
        Data päivittyy kerran päivässä. Käyttö on vapaata, kunhan mainitset lähteeksi Kultalaskuri.fi:n.
      </p>
      <p class="text-sm text-gray-500 leading-relaxed">
        Kysyttävää tai toiveita widgetiin? <a href="mailto:info@kultalaskuri.fi" class="text-gold-600 font-bold hover:underline">info@kultalaskuri.fi</a>
      </p>

    </div>
  </section>

  <script>
    const copyBtn = document.getElementById('copy-embed');
    copyBtn?.addEventListener('click', async () => {
      const code = copyBtn.getAttribute('data-code') ?? '';
      try {
        await navigator.clipboard.writeText(code);
        copyBtn.textContent = '✓ Kopioitu!';
        setTimeout(() => { copyBtn.textContent = 'Kopioi koodi'; }, 2000);
      } catch {}
    });
  </script>

</BaseLayout>
