---
import BaseLayout from '../layouts/BaseLayout.astro';

const dateModified = new Date().toISOString();

// Termit aakkosjärjestyksessä. definition = puhdas teksti schemaa varten,
// html = näkyvä versio sisäisillä linkeillä.
const terms = [
  {
    id: 'hankintameno-olettama',
    term: 'Hankintameno-olettama',
    definition: 'Verotuksen laskentatapa, jossa todellisen ostohinnan sijaan hankintamenona käytetään 20 % myyntihinnasta (omistus alle 10 vuotta) tai 40 % (omistus vähintään 10 vuotta). Hyödyllinen, kun vanhan korun ostohintaa ei tiedetä.',
    html: 'Verotuksen laskentatapa, jossa todellisen ostohinnan sijaan hankintamenona käytetään 20&nbsp;% myyntihinnasta (omistus alle 10 vuotta) tai 40&nbsp;% (omistus vähintään 10 vuotta). Hyödyllinen, kun vanhan korun ostohintaa ei tiedetä. Lue lisää <a href="/kullan-myynti-verotus/" class="text-gold-600 font-bold hover:underline">verotusoppaasta</a>.'
  },
  {
    id: 'karaatti',
    term: 'Karaatti (K)',
    definition: 'Kultapitoisuuden yksikkö, jossa puhdas kulta on 24 karaattia. Esimerkiksi 14K tarkoittaa, että seoksesta 14/24 eli 58,5 % on puhdasta kultaa. Huom: jalokivien painoyksikkö karaatti (ct) on eri asia.',
    html: 'Kultapitoisuuden yksikkö, jossa puhdas kulta on 24 karaattia. Esimerkiksi 14K tarkoittaa, että seoksesta 14/24 eli 58,5&nbsp;% on puhdasta kultaa. Huom: jalokivien painoyksikkö karaatti (ct) on eri asia.'
  },
  {
    id: 'kullattu',
    term: 'Kullattu (GP, GF, GE, HGE)',
    definition: 'Esine, jonka pinnassa on vain ohut kultakerros muun metallin päällä. Lyhenteet kuten GP (Gold Plated) ja GF (Gold Filled) kertovat pinnoitteesta. Kullatuilla esineillä ei ole käytännössä romukulta-arvoa.',
    html: 'Esine, jonka pinnassa on vain ohut kultakerros muun metallin päällä. Lyhenteet kuten GP (Gold Plated) ja GF (Gold Filled) kertovat pinnoitteesta. Kullatuilla esineillä ei ole käytännössä romukulta-arvoa. Katso <a href="/kullan-leimat/#tunnista-kotona" class="text-gold-600 font-bold hover:underline">miten tunnistat kullatun esineen</a>.'
  },
  {
    id: 'nimileima',
    term: 'Nimileima',
    definition: 'Valmistajan tai maahantuojan rekisteröity tunnus jalometalliesineessä. Suomessa nimileimat rekisteröi Tukes, ja rekisteri on julkinen. Nimileiman avulla voi selvittää korun valmistajan.',
    html: 'Valmistajan tai maahantuojan rekisteröity tunnus jalometalliesineessä. Suomessa nimileimat rekisteröi Tukes, ja rekisteri on julkinen. Nimileiman avulla voi selvittää korun valmistajan — katso <a href="/kullan-leimat/#nimileimat-vuosileimat" class="text-gold-600 font-bold hover:underline">nimileimat ja vuosileimat</a>.'
  },
  {
    id: 'pitoisuusleima',
    term: 'Pitoisuusleima',
    definition: 'Esineeseen lyöty luku, joka kertoo jalometallipitoisuuden tuhannesosina, esimerkiksi 585 (58,5 % kultaa) tai 750 (75 % kultaa). Suomessa pakollinen yli 1 gramman painoisissa kultatuotteissa.',
    html: 'Esineeseen lyöty luku, joka kertoo jalometallipitoisuuden tuhannesosina, esimerkiksi 585 (58,5&nbsp;% kultaa) tai 750 (75&nbsp;% kultaa). Suomessa pakollinen yli 1 gramman painoisissa kultatuotteissa. Katso <a href="/kullan-leimat/" class="text-gold-600 font-bold hover:underline">leimaopas</a>.'
  },
  {
    id: 'punakulta',
    term: 'Punakulta (rosekulta)',
    definition: 'Kultaseos, jossa on tavallista enemmän kuparia, mikä antaa punertavan sävyn. Pitoisuusleima (esim. 585) kertoo kultapitoisuuden — väri ei vaikuta romukulta-arvoon, vain kullan määrä.',
    html: 'Kultaseos, jossa on tavallista enemmän kuparia, mikä antaa punertavan sävyn. Pitoisuusleima (esim. 585) kertoo kultapitoisuuden — väri ei vaikuta romukulta-arvoon, vain kullan määrä.'
  },
  {
    id: 'romukulta',
    term: 'Romukulta',
    definition: 'Kultaesineet, jotka myydään metalliarvostaan sulatettaviksi: rikkinäiset korut, parittomat korvakorut, kuluneet sormukset ja hammaskulta. Romukullan arvo perustuu vain painoon ja pitoisuuteen, ei esineen kuntoon.',
    html: 'Kultaesineet, jotka myydään metalliarvostaan sulatettaviksi: rikkinäiset korut, parittomat korvakorut, kuluneet sormukset ja hammaskulta. Romukullan arvo perustuu vain painoon ja pitoisuuteen, ei esineen kuntoon. <a href="/#laskuri" class="text-gold-600 font-bold hover:underline">Laske romukullan arvo</a>.'
  },
  {
    id: 'sijoituskulta',
    term: 'Sijoituskulta',
    definition: 'Vähintään 995-pitoisuuden kultaharkot ja tietyt viralliset kultakolikot. Sijoituskullan osto on EU:ssa arvonlisäverotonta, mutta myyntivoitto on veronalaista pääomatuloa. Huomaa: kultakolikoista maksetaan tyypillisesti sulatusarvoa korkeampi hinta — älä myy kolikoita romukultana.',
    html: 'Vähintään 995-pitoisuuden kultaharkot ja tietyt viralliset kultakolikot. Sijoituskullan osto on EU:ssa arvonlisäverotonta, mutta myyntivoitto on veronalaista pääomatuloa — toisin kuin tavallisten korujen, katso <a href="/kullan-myynti-verotus/" class="text-gold-600 font-bold hover:underline">verotusopas</a>. <strong>Huomaa:</strong> kultakolikoista maksetaan tyypillisesti sulatusarvoa korkeampi hinta — älä myy kolikoita romukultana.'
  },
  {
    id: 'spot-hinta',
    term: 'Spot-hinta',
    definition: 'Puhtaan kullan välitön markkinahinta kansainvälisissä pörsseissä. Noteerataan dollareissa troy-unssilta ja muunnetaan euroiksi valuuttakurssilla. Kullanostajien hinnat johdetaan spot-hinnasta.',
    html: 'Puhtaan kullan välitön markkinahinta kansainvälisissä pörsseissä. Noteerataan dollareissa troy-unssilta ja muunnetaan euroiksi valuuttakurssilla. Kullanostajien hinnat johdetaan spot-hinnasta — seuraa <a href="/kullan-hinta/" class="text-gold-600 font-bold hover:underline">kullan hintakehitystä</a>.'
  },
  {
    id: 'tarkastusleima',
    term: 'Tarkastusleima (kruunuleima)',
    definition: 'Virallinen leima, joka osoittaa esineen jalometallipitoisuuden tarkastetuksi. Suomessa tarkastusleimana on käytetty kruunua.',
    html: 'Virallinen leima, joka osoittaa esineen jalometallipitoisuuden tarkastetuksi. Suomessa tarkastusleimana on käytetty kruunua.'
  },
  {
    id: 'tavoitehinta',
    term: 'Tavoitehinta (reilu vähimmäistaso)',
    definition: 'Kultalaskurin näyttämä hinta, joka vastaa tasoa, jonka luotettavat kullanostajat tyypillisesti vähintään maksavat. Se lasketaan kullan pörssiarvosta vähentämällä tyypilliset sulatus-, jalostus- ja katekulut.',
    html: 'Kultalaskurin näyttämä hinta, joka vastaa tasoa, jonka luotettavat kullanostajat tyypillisesti vähintään maksavat. Se lasketaan kullan pörssiarvosta vähentämällä tyypilliset sulatus-, jalostus- ja katekulut. Katso <a href="/tietoa/" class="text-gold-600 font-bold hover:underline">miten laskuri laskee arvon</a>.'
  },
  {
    id: 'troy-unssi',
    term: 'Troy-unssi (oz t)',
    definition: 'Jalometallien kansainvälinen painoyksikkö: 1 troy-unssi = 31,1035 grammaa. Kullan maailmanmarkkinahinta noteerataan dollareina troy-unssilta.',
    html: 'Jalometallien kansainvälinen painoyksikkö: 1 troy-unssi = 31,1035 grammaa. Kullan maailmanmarkkinahinta noteerataan dollareina troy-unssilta.'
  },
  {
    id: 'valkokulta',
    term: 'Valkokulta',
    definition: 'Kultaseos, jossa kulta on seostettu vaaleisiin metalleihin kuten palladiumiin tai hopeaan, ja pinta on usein rodinoitu hopeanhohtoiseksi. Valkokulta on aitoa kultaa: leima 585 tai 750 kertoo pitoisuuden, ja romukulta-arvo on sama kuin keltakullalla.',
    html: 'Kultaseos, jossa kulta on seostettu vaaleisiin metalleihin kuten palladiumiin tai hopeaan, ja pinta on usein rodinoitu hopeanhohtoiseksi. Valkokulta on aitoa kultaa: leima 585 tai 750 kertoo pitoisuuden, ja romukulta-arvo on sama kuin keltakullalla.'
  },
  {
    id: 'vuosileima',
    term: 'Vuosileima',
    definition: 'Kirjaimesta ja numerosta koostuva leima, joka kertoo esineen valmistusvuoden (esim. A10 = 2026). Suomalainen kirjainsarja alkoi vuonna 1810, ja kirjaimet kiertävät 24 vuoden jaksoissa.',
    html: 'Kirjaimesta ja numerosta koostuva leima, joka kertoo esineen valmistusvuoden (esim. A10 = 2026). Suomalainen kirjainsarja alkoi vuonna 1810, ja kirjaimet kiertävät 24 vuoden jaksoissa. Katso <a href="/kullan-leimat/#nimileimat-vuosileimat" class="text-gold-600 font-bold hover:underline">vuosileimataulukko</a>.'
  },
  {
    id: 'xrf-mittaus',
    term: 'XRF-mittaus',
    definition: 'Röntgenfluoresenssiin perustuva analyysi, jolla jalometallin pitoisuus voidaan mitata tarkasti esinettä vahingoittamatta. Käytössä kullanostajilla ja pantti- sekä jalometalliliikkeissä erityisesti leimattomien esineiden arvioinnissa.',
    html: 'Röntgenfluoresenssiin perustuva analyysi, jolla jalometallin pitoisuus voidaan mitata tarkasti esinettä vahingoittamatta. Käytössä kullanostajilla ja pantti- sekä jalometalliliikkeissä erityisesti leimattomien esineiden arvioinnissa.'
  },
];

const schemaData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://kultalaskuri.fi/#website",
      "url": "https://kultalaskuri.fi",
      "name": "Kultalaskuri.fi",
      "inLanguage": "fi-FI"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Kultalaskuri.fi", "item": "https://kultalaskuri.fi" },
        { "@type": "ListItem", "position": 2, "name": "Kultasanasto", "item": "https://kultalaskuri.fi/sanasto/" }
      ]
    },
    {
      "@type": "WebPage",
      "@id": "https://kultalaskuri.fi/sanasto/",
      "url": "https://kultalaskuri.fi/sanasto/",
      "name": "Kultasanasto – kullan myynnin ja jalometallien termit selkokielellä",
      "description": "Mitä tarkoittaa karaatti, spot-hinta, hankintameno-olettama tai XRF-mittaus? Kultasanasto selittää kullan myynnin ja jalometallien termit selkokielellä.",
      "inLanguage": "fi-FI",
      "dateModified": dateModified,
      "isPartOf": { "@id": "https://kultalaskuri.fi/#website" }
    },
    {
      "@type": "DefinedTermSet",
      "@id": "https://kultalaskuri.fi/sanasto/#termset",
      "name": "Kultasanasto",
      "inLanguage": "fi-FI",
      "hasDefinedTerm": terms.map(t => ({
        "@type": "DefinedTerm",
        "@id": `https://kultalaskuri.fi/sanasto/#${t.id}`,
        "name": t.term,
        "description": t.definition,
        "inDefinedTermSet": "https://kultalaskuri.fi/sanasto/#termset"
      }))
    }
  ]
};
---

<BaseLayout
  title="Kultasanasto – kullan termit selkokielellä | Kultalaskuri.fi"
  description="Mitä tarkoittaa karaatti, spot-hinta, hankintameno-olettama tai XRF-mittaus? Kultasanasto selittää kullan myynnin ja jalometallien termit selkokielellä."
  schema={JSON.stringify(schemaData)}
>

  <div class="relative bg-[#0B0F19] pt-28 pb-20 px-4 overflow-hidden">
    <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
      <div class="absolute top-0 right-1/4 w-96 h-96 bg-gold-400/15 rounded-full mix-blend-screen filter blur-[120px] animate-blob"></div>
    </div>

    <div class="max-w-3xl mx-auto relative z-10 text-center">
      <nav aria-label="Murupolku" class="mb-6">
        <ol class="flex items-center justify-center gap-2 text-xs text-gray-500">
          <li><a href="/" class="hover:text-gold-400 transition-colors">Etusivu</a></li>
          <li aria-hidden="true">›</li>
          <li aria-current="page" class="text-gray-400">Kultasanasto</li>
        </ol>
      </nav>

      <h1 class="text-3xl md:text-5xl font-black text-white mb-4 leading-tight tracking-tight">
        Kulta<span class="text-transparent bg-clip-text bg-gradient-to-r from-gold-200 to-gold-600">sanasto</span>
      </h1>
      <p class="text-sm md:text-base text-gray-400 leading-relaxed max-w-2xl mx-auto">
        Kullan myynnissä ja jalometalleissa vilisee termejä. Tämä sanasto selittää ne
        selkokielellä — aakkosjärjestyksessä, ilman jargonia.
      </p>
    </div>
  </div>

  <section class="bg-white py-16 px-4">
    <div class="max-w-3xl mx-auto">

      {/* Termilinkit */}
      <nav aria-label="Termit" class="mb-12 flex flex-wrap gap-2">
        {terms.map(t => (
          <a href={`#${t.id}`} class="px-3 py-1.5 rounded-full bg-gray-50 border border-gray-200 text-xs font-bold text-gray-600 hover:border-gold-300 hover:text-gold-700 transition-colors">
            {t.term.split(' (')[0]}
          </a>
        ))}
      </nav>

      <dl class="space-y-8 mb-16">
        {terms.map(t => (
          <div id={t.id} class="scroll-mt-24 pb-8 border-b border-gray-100 last:border-b-0">
            <dt class="text-xl font-black text-gray-900 mb-2">{t.term}</dt>
            <dd class="text-gray-600 leading-relaxed" set:html={t.html} />
          </div>
        ))}
      </dl>

      <div class="bg-[#0B0F19] rounded-3xl p-8 md:p-10 text-center">
        <h2 class="text-2xl md:text-3xl font-black text-white mb-3">Termit hallussa — entä kultasi arvo?</h2>
        <p class="text-gray-400 mb-6 max-w-xl mx-auto">Syötä paino ja pitoisuus, niin näet reilun tavoitehinnan päivän kurssilla.</p>
        <a href="/#laskuri" class="inline-flex items-center justify-center gap-2 bg-gold-500 text-[#0B0F19] px-8 py-4 rounded-xl font-bold hover:bg-white transition-all duration-300 shadow-xl">
          Laske kultasi arvo →
        </a>
      </div>

    </div>
  </section>

</BaseLayout>
