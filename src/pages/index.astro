---
import BaseLayout from '../layouts/BaseLayout.astro';
import GoldPriceChart from '../components/react/GoldPriceChart.tsx';
import priceHistory from '../../social/data/price-history.json';
import { getGoldPrice } from '../lib/api/metalPriceApi';
import GoldCalculator from '../components/react/GoldCalculator.tsx';
import JewelryWeightEstimator from '../components/react/JewelryWeightEstimator.tsx';
import { generateIndexSchema } from '../lib/seo';
import { calculateGoldValue } from '../lib/calculations/goldCalculator';
import PriceCard from '../components/PriceCard.astro';
import FaqItem from '../components/FaqItem.astro';


// ── Hintatiedot ──
const goldPrice = await getGoldPrice();
const spot = goldPrice?.priceEurGram || 0;

// Muutos edellisestä pörssipäivästä: verrataan tuoretta spot-hintaa viimeisimpään
// hintahistorian pisteeseen, joka EI ole tältä päivältä (build ajetaan tunneittain,
// historia tallennetaan kerran päivässä klo 18).
// Kaikki aikaleimat Suomen ajassa — build ajetaan UTC-palvelimella,
// joten aikavyöhyke on annettava eksplisiittisesti
const HELSINKI_TZ = 'Europe/Helsinki';

const lastHist = priceHistory[priceHistory.length - 1];
const prevHist = priceHistory[priceHistory.length - 2];
const buildDay = new Date().toLocaleDateString('sv-SE', { timeZone: HELSINKI_TZ }); // YYYY-MM-DD Suomen ajassa
const refHist = lastHist?.date === buildDay ? prevHist : lastHist;
const dayChangePct = spot > 0 && refHist && refHist.price > 0
  ? ((spot - refHist.price) / refHist.price) * 100
  : null;
// Viikonloppuna pörssi on kiinni eikä hinta liiku — piilotetaan nollamuutos
const showDayChange = dayChangePct !== null && Math.abs(dayChangePct) >= 0.05;
const dayChangeUp = (dayChangePct ?? 0) >= 0;

// Näkyvä päivitysaika — täsmällinen aikaleima on vahvempi trust-signaali kuin "reaaliaikainen".
// Tuotannossa build ajetaan tunneittain, joten myös kellonaika näytetään.
// Fallback-datassa (hintahistoria) aikaleima on keskiyöllä → näytetään vain päivämäärä.
const updatedAtDate = goldPrice?.updatedAt ? new Date(goldPrice.updatedAt) : new Date();
const updatedDate = updatedAtDate.toLocaleDateString('fi-FI', {
  day: 'numeric', month: 'numeric', year: 'numeric', timeZone: HELSINKI_TZ,
});
// Fallback-datan aikaleima on keskiyöllä → kellonaikaa ei näytetä ('00.00').
// Oikea API-haku osuu keskiyöhön käytännössä vain teoriassa.
const timeStr = updatedAtDate.toLocaleTimeString('fi-FI', {
  hour: '2-digit', minute: '2-digit', timeZone: HELSINKI_TZ,
});
const updatedTime = timeStr === '00.00' ? null : timeStr;
// Mobiilissa lyhyt muoto ilman vuotta, jotta badge mahtuu yhdelle riville
const updatedDateShort = updatedAtDate.toLocaleDateString('fi-FI', {
  day: 'numeric', month: 'numeric', timeZone: HELSINKI_TZ,
});

const result24k = spot > 0 ? calculateGoldValue(1, '24K', spot) : null;
const result18k = spot > 0 ? calculateGoldValue(1, '18K', spot) : null;
const result14k = spot > 0 ? calculateGoldValue(1, '14K', spot) : null;

const p24k = result24k?.targetValue ?? 0;
const p18k = result18k?.targetValue ?? 0;
const p14k = result14k?.targetValue ?? 0;

const schemaData = generateIndexSchema(spot, p14k.toFixed(2).replace('.', ','), new Date().toISOString());

// ── Data-taulukot toistorakenteita varten ──

const priceCards = [
  { karat: '14K', purity: 585, label: 'Suomen yleisin', price: p14k, isHighlighted: true },
  { karat: '18K', purity: 750, label: 'Arvokorut', price: p18k },
  { karat: '24K', purity: 999, label: 'Puhdas kulta', price: p24k },
];

const iconSvgAttrs = 'xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"';

const benefitCards = [
  {
    icon: `<svg ${iconSvgAttrs}><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>`,
    title: 'Tiedä oikea markkinahinta',
    text: 'Kullan hinta muuttuu joka päivä. Kun tiedät ajantasaisen <span class="font-semibold text-gold-600">pörssikurssin</span>, olet vahvemmassa asemassa neuvotteluissa kullanostajien kanssa. Älä myy sokkona.'
  },
  {
    icon: `<svg ${iconSvgAttrs}><path d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="m2 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="M7 21h10"/><path d="M12 3v18"/><path d="M3 7h2c2 0 5-1 7-2 2 1 5 2 7 2h2"/></svg>`,
    title: 'Tunnista arvoesineet',
    text: 'Kaikki kulta ei ole samanarvoista. 18 karaatin vihkisormus on arvokkaampi kuin 14 karaatin ketju. Laskurimme auttaa sinua hahmottamaan eri pitoisuuksien hintaerot.'
  },
  {
    icon: `<svg ${iconSvgAttrs}><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-1 1.5-2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>`,
    title: 'Kilpailuttaminen kannattaa',
    text: 'Ostajien hinnoissa on eroja. Kun olet laskenut esineesi suuntaa-antavan arvon laskurillamme, tiedät onko saamasi tarjous reilu vai kannattaako kysyä hintaa muualta. <a href="/kullan-myynti/" class="text-gold-600 font-bold hover:underline">Lue oppaamme kullan myymisestä →</a>'
  },
];

const stampCards = [
  { purity: '585', karat: '14 Karaattia', desc: 'Suomen yleisin korukulta. Sisältää 58,5% puhdasta kultaa.' },
  { purity: '750', karat: '18 Karaattia', desc: 'Arvokorut ja vihkisormukset. Sisältää 75% puhdasta kultaa.' },
  { purity: '999', karat: '24 Karaattia', desc: 'Puhdas sijoituskulta, kuten kultaharkot.' },
];

const faqItems = [
  { 
    question: 'Paljonko on kullan hinta grammalta?', 
    answer: `Kullan hinta grammalta vaihtelee pörssikurssin mukaan. Juuri nyt puhtaan kullan (24K) markkinahinta on noin <strong>${spot > 0 ? spot.toFixed(2).replace('.', ',') + ' €/g' : 'tarkistettavissa laskuristamme'}</strong>.`
  },
  { 
    question: 'Mitä eroa on 14K ja 18K kullalla?', 
    answer: 'Ero on kultapitoisuudessa. 14K (leima 585) sisältää 58,5 % puhdasta kultaa ja on kovempaa, mikä tekee siitä Suomen yleisimmän korumateriaalin. 18K (leima 750) sisältää 75 % kultaa; se on arvokkaampaa ja väriltään syvemmän keltaista, mutta pehmeämpänä se naarmuuntuu helpommin.'
  },
  { 
    question: 'Mitä tarkoittaa leima 585?', 
    answer: 'Leima 585 tarkoittaa 14 karaatin kultaa. Luku kertoo, että seoksesta 585 tuhannesosaa (eli 58,5 %) on puhdasta kultaa. Loput ovat seosmetalleja, kuten kuparia ja hopeaa, jotka tekevät korusta kestävämmän.'
  },
  { 
    question: 'Paljonko kultasormus tai ketju painaa?', 
    answer: 'Korujen paino vaihtelee suuresti. Kevyt naisten sormus painaa tyypillisesti 2–4 grammaa, kun taas tukevampi miesten sormus voi painaa 5–10 grammaa. Ohut kaulaketju voi olla alle 3 grammaa, mutta paksut panssariketjut voivat painaa kymmeniä grammoja.'
  },
  { 
    question: 'Onko kultakoruissa aina leima?', 
    answer: 'Suomessa myytävissä, yli 1 gramman painoisissa kultatuotteissa tulee lain mukaan olla pitoisuusleima. Hyvin vanhoissa koruissa, ulkomailta tuoduissa esineissä tai itse tehdyissä töissä leima voi kuitenkin puuttua tai se on voinut kulua näkymättömiin.'
  },
  { 
    question: 'Mistä tietää onko esine kultaa vai kullattu?', 
    answer: 'Varmin keino on etsiä leimat (esim. 585 tai 750). Toinen kotikonsti on magneetti: aito kulta ei ole magneettista. Jos koru tarttuu magneettiin, se on todennäköisesti kullattua rautaa. Myös kuluneet kohdat, joista paistaa toinen väri läpi, paljastavat esineen olevan vain kullattu.'
  },
  { 
    question: 'Kannattaako kulta myydä juuri nyt?', 
    answer: 'Kullan hinta on historiallisesti erittäin korkealla tasolla. Jos sinulla on tarpeettomia koruja, rikkinäistä kultaa tai parittomia korvakoruja, nykyinen markkinatilanne on myyjän kannalta erinomainen. <a href="/kullan-myynti/" class="text-gold-600 font-bold hover:underline">Lue vinkkimme kullan myymiseen →</a>'
  },
  { 
    question: 'Miten kullan maailmanmarkkinahinta määräytyy?', 
    answer: 'Kullan hinta (spot-hinta) määräytyy kansainvälisissä pörsseissä kysynnän ja tarjonnan mukaan. Siihen vaikuttavat maailmantalouden tilanne, dollarin kurssi, inflaatio ja geopoliittinen epävarmuus. Kultalaskuri.fi seuraa tätä hintaa päivittäin — katso <a href="/kullan-hinta/" class="text-gold-600 font-bold hover:underline">kullan hintakehitys</a>.'
  },
];
---

<BaseLayout 
  title="Kullan hinta tänään – Laske kultasi arvo | Kultalaskuri.fi" 
  description="Kullan hinta tänään päivittyvällä pörssikurssilla. Ilmainen ja puolueeton kultalaskuri näyttää kultakorujen ja romukullan reilun myyntihinnan sekunneissa."
  schema={schemaData}
>

  <div class="relative bg-[#0B0F19] pt-28 pb-12 px-4 overflow-hidden">

    {/* Blob-taustaefektit (kevyt CSS-only) */}
    <div class="absolute inset-0 overflow-hidden pointer-events-none z-0 no-print">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-gold-400/20 rounded-full mix-blend-screen filter blur-[100px] animate-blob"></div>
      <div class="absolute top-10 right-1/4 w-96 h-96 bg-blue-600/20 rounded-full mix-blend-screen filter blur-[100px] animate-blob animation-delay-2000"></div>
    </div>

    <div class="max-w-4xl mx-auto text-center relative z-10 no-print">

      {/* Päivitysaika-indikaattori — täsmällinen aikaleima herättää luottamusta.
          Mobiilissa lyhyt muoto, jotta pallukka ja teksti pysyvät samalla rivillä. */}
      <div class="flex items-center justify-center gap-2 mb-4 pointer-events-none select-none whitespace-nowrap">
        <span class="relative flex h-2 w-2 shrink-0">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
        </span>
        <span class="text-gray-400 text-[11px] sm:text-xs uppercase tracking-widest sm:tracking-[0.2em] font-medium">
          <span class="sm:hidden">Päivitetty {updatedDateShort}{updatedTime && ` klo ${updatedTime}`}</span>
          <span class="hidden sm:inline">Pörssihinta · päivitetty {updatedDate}{updatedTime && ` klo ${updatedTime}`}</span>
        </span>
      </div>

      {/* ISO HINTANÄYTTÖ — ei animaatiota, arvo näkyy heti */}
      <div class="mb-3">
        <div class="flex items-end justify-center gap-2 md:gap-4">
          <span
            class="text-6xl md:text-8xl lg:text-9xl font-black text-white tracking-tight tabular-nums leading-none"
          >
            {spot > 0 ? spot.toFixed(2).replace('.', ',') : '--'}
          </span>
          <div class="flex flex-col items-start pb-1 md:pb-3">
            <span class="text-gold-400 text-2xl md:text-4xl font-black leading-none">€</span>
            <span class="text-gray-500 text-xs md:text-sm font-medium leading-tight mt-1">/ g &middot; 24K</span>
          </div>
        </div>

        {/* Muutos edellisestä pörssipäivästä — syy tarkistaa hinta joka päivä.
            Piilossa viikonloppuisin, kun pörssi on kiinni eikä hinta liiku. */}
        {showDayChange ? (
          <p class={`mt-3 text-sm font-bold tabular-nums ${dayChangeUp ? 'text-emerald-400' : 'text-red-400'}`}>
            {dayChangeUp ? '▲' : '▼'} {Math.abs(dayChangePct!).toFixed(1).replace('.', ',')} % edellisestä pörssipäivästä
            <a href="/kullan-hinta/" class="ml-2 text-gray-500 font-medium hover:text-gray-300 transition-colors underline underline-offset-2">
              Katso hintakehitys
            </a>
          </p>
        ) : (
          <p class="mt-3 text-sm">
            <a href="/kullan-hinta/" class="text-gray-500 font-medium hover:text-gray-300 transition-colors underline underline-offset-2">
              Katso hintakehitys
            </a>
          </p>
        )}
      </div>

      {/* Luottamusrivi */}
      <div class="flex items-center justify-center mb-7 text-[10.5px] sm:text-[11px] uppercase tracking-wider sm:tracking-widest text-gray-500 select-none no-print">
        <span class="inline-flex items-center gap-1.5">
          <span class="text-xs sm:text-sm" aria-hidden="true">🇫🇮</span>
          <span>Suomalainen palvelu</span>
        </span>
      </div>

      <h1 class="text-3xl md:text-5xl font-black text-white mb-6 leading-tight drop-shadow-lg">
        Kullan hinta tänään —
        <span class="block text-transparent bg-clip-text bg-gradient-to-r from-gold-200 via-gold-400 to-gold-600">
          laske kultasi arvo
        </span>
      </h1>
    </div>

    {/* Laskuri suoraan hero-osioon — above the fold */}
    <div id="laskuri" class="max-w-5xl mx-auto relative z-10">
      <div class="bg-white rounded-[2rem] shadow-[0_25px_50px_-12px_rgba(0,0,0,0.25)] border border-gray-100 overflow-hidden p-1 md:p-2">
        {goldPrice ? (
          <GoldCalculator client:load spotPriceEurPerGram={goldPrice.priceEurGram} />
        ) : (
          <div class="text-center p-12">
            <p class="text-red-500">Hintatietoja ei saatavilla.</p>
          </div>
        )}
      </div>
    </div>
  </div>

  {/* Mobiilihintastrippi — näkyy vain mobiilissa laskurin ja hintakorttien välissä */}
  {spot > 0 && (
    <div class="md:hidden bg-[#0B0F19] border-t border-white/5 px-4 py-4">
      <p class="text-[11px] uppercase tracking-widest text-gray-400 text-center mb-3 font-bold">Tavoitehinnat tänään</p>
      <div class="grid grid-cols-3 gap-2">
        {priceCards.map(card => (
          <div class={`text-center py-3 px-2 rounded-xl border ${card.isHighlighted ? 'border-gold-400/40 bg-gold-400/10' : 'border-white/10 bg-white/5'}`}>
            <p class="text-xs font-bold text-gray-400 mb-1">{card.karat}</p>
            <p class={`text-sm font-black tabular-nums leading-tight ${card.isHighlighted ? 'text-gold-400' : 'text-white'}`}>
              {card.price.toFixed(2).replace('.', ',')}
            </p>
            <p class="text-xs text-gray-400 mt-0.5">€/g</p>
          </div>
        ))}
      </div>
      <a href="#leimat" class="flex items-center justify-center gap-1.5 mt-3 text-xs text-gray-400 hover:text-gray-200 transition-colors">
        <span>Tunnista kullan leimat</span>
        <span>↓</span>
      </a>
    </div>
  )}

  <div class="px-4 pb-12 pt-16">
    <div class="max-w-5xl mx-auto">

      <div>
        <div class="text-center mb-10">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-green-50 text-green-700 text-[10px] md:text-xs font-bold uppercase tracking-wide mb-4 border border-green-100 shadow-sm">
            <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
            Päivitetty automaattisesti
          </div>
          <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-4 tracking-tight">Arvioidut myyntihinnat</h2>
          <p class="text-gray-500 text-sm md:text-base max-w-2xl mx-auto leading-relaxed">
            Realistiset <strong class="text-gray-700">tavoitehinnat</strong> yleisimmille kultapitoisuuksille —
            taso, jonka luotettavat ostajat tyypillisesti vähintään maksavat.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 price-card-grid">
          {priceCards.map(card => (
            <PriceCard
              karat={card.karat}
              purity={card.purity}
              label={card.label}
              price={card.price}
              isHighlighted={card.isHighlighted}
            />
          ))}
        </div>
      </div>
    </div>
  </div>

  <section id="vaaka" class="py-20 bg-white border-t border-gray-100 scroll-mt-24">
    <div class="max-w-4xl mx-auto px-4">
      <JewelryWeightEstimator client:visible spotPrice={spot} />
    </div>
  </section>

  <section id="hintahistoria" class="py-20 bg-[#0B0F19] border-t border-white/5 scroll-mt-24">
    <div class="max-w-5xl mx-auto px-4">

      <div class="text-center mb-10 reveal">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-gold-400/10 text-gold-400 text-[10px] font-bold uppercase tracking-widest mb-4 border border-gold-400/20">
          <span class="w-1.5 h-1.5 rounded-full bg-gold-400 animate-pulse"></span>
          Päivittäinen hintaseuranta
        </div>
        <h2 class="text-3xl md:text-4xl font-black text-white mb-4 tracking-tight">
          Kullan hintakehitys
        </h2>
        <p class="text-gray-400 text-sm md:text-base max-w-2xl mx-auto leading-relaxed">
          Seuraamme kullan spot-hinnan kehitystä päivittäin euroissa per gramma.
          Vertaa nykyhintaa lähihistoriaan ja arvioi, onko tämä hyvä hetki myydä kultaa.
        </p>
      </div>

      {/* min-h varaa tilan islandille → ei layout-hyppäystä hydraatiossa (CLS) */}
      <div class="reveal min-h-[560px] md:min-h-[480px]">
        <GoldPriceChart client:visible data={priceHistory} />
      </div>

      <p class="text-center text-gray-400 text-xs mt-6 leading-relaxed">
        Kullan spot-hinta euroina per gramma (24K, puhdas kulta). Päivitetään päivittäin klo 18.
        Lähde: MetalPrice API · {priceHistory.length} päivän historia · Historiallinen kehitys ei ennusta tulevaa hintaa.
      </p>

      <p class="text-center mt-4">
        <a href="/kullan-hinta/" class="inline-flex items-center gap-1.5 text-gold-400 font-bold hover:underline text-sm">
          Katso koko hintahistoria ja kuukausitilastot →
        </a>
      </p>

    </div>
  </section>

  <section id="leimat" class="py-16 bg-gray-50 border-t border-gray-100">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-16 items-center">

        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white text-gold-700 text-[10px] font-bold uppercase tracking-widest mb-4 border border-gold-200 shadow-sm">
            <span class="w-1.5 h-1.5 rounded-full bg-gold-400"></span>
            Tunnistusopas
          </div>
          <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-6 tracking-tight">Näin tunnistat arvokkaan kullan</h2>
          <div class="space-y-6 text-gray-600 leading-relaxed">
            <p>
              Kaikki keltainen ei ole kultaa. Ennen myyntiä on hyvä tarkistaa, 
              onko korusi aitoa jalometallia vai vain kullattua metallia. Tärkein tuntomerkki on leima.
            </p>
            
            <h3 class="text-xl font-bold text-gray-900 mt-8 mb-3">Tunnista kultaleimat (585, 750, 999)</h3>
            <p>
              Jalometallituotteissa on lähes aina leima, joka kertoo pitoisuuden. 
              Suomessa yleisin leima on <strong>585</strong>, mikä tarkoittaa 14 karaatin kultaa (58,5% puhdasta kultaa).
            </p>
            
            <ul class="space-y-3 mt-6">
              <li class="flex items-start gap-3">
                <span class="w-6 h-6 rounded-full bg-green-100 text-green-600 flex items-center justify-center shrink-0 mt-0.5">✓</span>
                <span><strong>Etsi leimat:</strong> Tarkista korun sisäpinta tai lukko suurennuslasilla. Aidoissa koruissa on lähes aina pitoisuusleima (esim. 585 tai 750).</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="w-6 h-6 rounded-full bg-green-100 text-green-600 flex items-center justify-center shrink-0 mt-0.5">✓</span>
                <span><strong>Magneettitesti:</strong> Aito kulta ei ole magneettista. Jos koru tarttuu napakasti magneettiin, se on todennäköisesti kullattua rautaa tai terästä.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="w-6 h-6 rounded-full bg-green-100 text-green-600 flex items-center justify-center shrink-0 mt-0.5">✓</span>
                <span><strong>Tarkista kulumat:</strong> Aito kulta on samanväristä myös pinnan alta. Jos naarmuista tai reunoista kuultaa läpi harmaa tai punertava metalli, esine on vain kullattu.</span>
              </li>
            </ul>

            <div class="mt-8 p-4 bg-gold-50/30 border border-gold-100/50 rounded-xl shadow-sm flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-white flex items-center justify-center shrink-0 shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gold-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-1 1.5-2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/>
                  <path d="M9 18h6"/>
                  <path d="M10 22h4"/>
                </svg>
              </div>
              <div>
                <h4 class="font-bold text-gray-900 text-sm">Vinkki: Puuttuuko suurennuslasi?</h4>
                <p class="text-sm text-gray-600 mt-1">
                  Voit kokeilla ottaa leimasta kuvan puhelimellasi hyvässä valossa. 
                  Kun zoomaat valmista kuvaa puhelimen näytöllä, näet pienetkin numerot usein yllättävän tarkasti.
                </p>
              </div>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-6">
          {stampCards.map(card => (
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 flex items-center gap-6 group hover:border-gold-300 transition-colors">
              <div class="w-16 h-16 bg-gold-50 rounded-full flex items-center justify-center text-gold-600 font-bold text-xl border border-gold-100 shrink-0">
                {card.purity}
              </div>
              <div>
                <h4 class="font-bold text-gray-900 text-lg">{card.karat}</h4>
                <p class="text-sm text-gray-500">{card.desc}</p>
              </div>
            </div>
          ))}
