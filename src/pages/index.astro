---
import BaseLayout from '../layouts/BaseLayout.astro';
import GoldChart from '../components/react/GoldChart.tsx';
import { getGoldPrice } from '../lib/api/metalPriceApi';
import GoldCalculator from '../components/react/GoldCalculator.tsx';
import JewelryWeightEstimator from '../components/react/JewelryWeightEstimator.tsx';
import { generateIndexSchema } from '../lib/seo';
import { calculateGoldValue } from '../lib/calculations/goldCalculator';
import PriceCard from '../components/PriceCard.astro';
import FaqItem from '../components/FaqItem.astro';


// ── Hintatiedot ──
const goldPrice = await getGoldPrice();
const spot = goldPrice?.priceEurGram || 0;

const result24k = spot > 0 ? calculateGoldValue(1, '24K', spot) : null;
const result18k = spot > 0 ? calculateGoldValue(1, '18K', spot) : null;
const result14k = spot > 0 ? calculateGoldValue(1, '14K', spot) : null;

const p24k = result24k?.targetValue ?? 0;
const p18k = result18k?.targetValue ?? 0;
const p14k = result14k?.targetValue ?? 0;

const schemaData = generateIndexSchema(spot, p14k.toFixed(2));

// ── Data-taulukot toistorakenteita varten ──

const priceCards = [
  { karat: '14K', purity: 585, label: 'Suomen yleisin', price: p14k, isHighlighted: true },
  { karat: '18K', purity: 750, label: 'Arvokorut', price: p18k },
  { karat: '24K', purity: 999, label: 'Puhdas kulta', price: p24k },
];

const benefitCards = [
  { 
    icon: '📊', 
    iconLabel: 'Tilastokuvake',
    title: 'Tiedä oikea markkinahinta', 
    text: 'Kullan hinta muuttuu joka päivä. Kun tiedät ajantasaisen <span class="font-semibold text-gold-600">pörssikurssin</span>, olet vahvemmassa asemassa neuvotteluissa kullanostajien kanssa. Älä myy sokkona.'
  },
  { 
    icon: '⚖️', 
    iconLabel: 'Vaaka',
    title: 'Tunnista arvoesineet', 
    text: 'Kaikki kulta ei ole samanarvoista. 18 karaatin vihkisormus on arvokkaampi kuin 14 karaatin ketju. Laskurimme auttaa sinua hahmottamaan eri pitoisuuksien hintaerot.'
  },
  { 
    icon: '💡', 
    iconLabel: 'Vinkkilamppu',
    title: 'Kilpailuttaminen kannattaa', 
    text: 'Ostajien hinnoissa on eroja. Kun olet laskenut esineesi suuntaa-antavan arvon laskurillamme, tiedät onko saamasi tarjous reilu vai kannattaako kysyä hintaa muualta. <a href="/kullan-myynti/" class="text-gold-600 font-bold hover:underline">Lue oppaamme kullan myymisestä →</a>'
  },
];

const stampCards = [
  { purity: '585', karat: '14 Karaattia', desc: 'Suomen yleisin korukulta. Sisältää 58,5% puhdasta kultaa.' },
  { purity: '750', karat: '18 Karaattia', desc: 'Arvokorut ja vihkisormukset. Sisältää 75% puhdasta kultaa.' },
  { purity: '999', karat: '24 Karaattia', desc: 'Puhdas sijoituskulta, kuten kultaharkot ja kolikot.' },
];

const faqItems = [
  { 
    question: 'Paljonko on kullan hinta grammalta?', 
    answer: `Kullan hinta grammalta vaihtelee pörssikurssin mukaan. Juuri nyt puhtaan kullan (24K) markkinahinta on noin <strong>${spot > 0 ? spot.toFixed(2) + ' €/g' : 'tarkistettavissa laskuristamme'}</strong>.`
  },
  { 
    question: 'Mitä eroa on 14K ja 18K kullalla?', 
    answer: 'Ero on kultapitoisuudessa. 14K (leima 585) sisältää 58,5 % puhdasta kultaa ja on kovempaa, mikä tekee siitä Suomen yleisimmän korumateriaalin. 18K (leima 750) sisältää 75 % kultaa; se on arvokkaampaa ja väriltään syvemmän keltaista, mutta pehmeämpänä se naarmuuntuu helpommin.'
  },
  { 
    question: 'Mitä tarkoittaa leima 585?', 
    answer: 'Leima 585 tarkoittaa 14 karaatin kultaa. Luku kertoo, että seoksesta 585 tuhannesosaa (eli 58,5 %) on puhdasta kultaa. Loput ovat seosmetalleja, kuten kuparia ja hopeaa, jotka tekevät korusta kestävämmän.'
  },
  { 
    question: 'Paljonko kultasormus tai ketju painaa?', 
    answer: 'Korujen paino vaihtelee suuresti. Kevyt naisten sormus painaa tyypillisesti 2–4 grammaa, kun taas tukevampi miesten sormus voi painaa 5–10 grammaa. Ohut kaulaketju voi olla alle 3 grammaa, mutta paksut panssariketjut voivat painaa kymmeniä grammoja.'
  },
  { 
    question: 'Onko kultakoruissa aina leima?', 
    answer: 'Suomessa myytävissä, yli 1 gramman painoisissa kultatuotteissa tulee lain mukaan olla pitoisuusleima. Hyvin vanhoissa koruissa, ulkomailta tuoduissa esineissä tai itse tehdyissä töissä leima voi kuitenkin puuttua tai se on voinut kulua näkymättömiin.'
  },
  { 
    question: 'Mistä tietää onko esine kultaa vai kullattu?', 
    answer: 'Varmin keino on etsiä leimat (esim. 585 tai 750). Toinen kotikonsti on magneetti: aito kulta ei ole magneettista. Jos koru tarttuu magneettiin, se on todennäköisesti kullattua rautaa. Myös kuluneet kohdat, joista paistaa toinen väri läpi, paljastavat esineen olevan vain kullattu.'
  },
  { 
    question: 'Kannattaako kulta myydä juuri nyt?', 
    answer: 'Kullan hinta on historiallisesti erittäin korkealla tasolla. Jos sinulla on tarpeettomia koruja, rikkinäistä kultaa tai parittomia korvakoruja, nykyinen markkinatilanne on myyjän kannalta erinomainen. <a href="/kullan-myynti/" class="text-gold-600 font-bold hover:underline">Lue vinkkimme kullan myymiseen →</a>'
  },
  { 
    question: 'Miten kullan maailmanmarkkinahinta määräytyy?', 
    answer: 'Kullan hinta (spot-hinta) määräytyy kansainvälisissä pörsseissä kysynnän ja tarjonnan mukaan. Siihen vaikuttavat maailmantalouden tilanne, dollarin kurssi, inflaatio ja geopoliittinen epävarmuus. Kultalaskuri.fi seuraa tätä hintaa reaaliajassa.'
  },
];
---

<BaseLayout 
  title="Kullan hinta tänään – Laske kultasi arvo | Kultalaskuri.fi" 
  description="Tarkista kullan hinta tänään reaaliajassa. Ilmainen ja puolueeton kultalaskuri näyttää kultakorujesi ja romukullan tarkan arvon helposti ja nopeasti."
  schema={schemaData}
>

  <div class="relative bg-[#0B0F19] pt-28 pb-48 px-4 overflow-hidden">

    {/* Partikkelianimaatio */}
    <canvas id="hero-particles" class="absolute inset-0 w-full h-full z-0 pointer-events-none"></canvas>

    {/* Blob-animaatiot */}
    <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-gold-400/20 rounded-full mix-blend-screen filter blur-[100px] animate-blob"></div>
      <div class="absolute top-10 right-1/4 w-96 h-96 bg-blue-600/20 rounded-full mix-blend-screen filter blur-[100px] animate-blob animation-delay-2000"></div>
    </div>

    <div class="max-w-4xl mx-auto text-center relative z-10 reveal active">

      {/* Live-indikaattori */}
      <div class="flex items-center justify-center gap-2 mb-6">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
        </span>
        <span class="text-gray-400 text-xs uppercase tracking-[0.2em] font-medium">Reaaliaikainen pörssihinta</span>
      </div>

      {/* ISO HINTANÄYTTÖ */}
      <div class="mb-4">
        <div class="flex items-end justify-center gap-2 md:gap-4">
          <span
            id="hero-spot-price"
            data-target={spot > 0 ? spot.toFixed(2) : ''}
            class="text-6xl md:text-8xl lg:text-9xl font-black text-white tracking-tight tabular-nums leading-none"
          >
            {spot > 0 ? spot.toFixed(2) : '--'}
          </span>
          <div class="flex flex-col items-start pb-1 md:pb-3">
            <span class="text-gold-400 text-2xl md:text-4xl font-black leading-none">€</span>
            <span class="text-gray-500 text-xs md:text-sm font-medium leading-tight mt-1">/ g &middot; 24K</span>
          </div>
        </div>
      </div>

      {/* Lähde */}
      <p class="text-gray-600 text-[11px] uppercase tracking-widest mb-10">Lähde: Metalprice API</p>

      <h1 class="text-3xl md:text-5xl font-black text-white mb-4 leading-tight drop-shadow-lg">
        Kullan hinta tänään —
        <span class="block text-transparent bg-clip-text bg-gradient-to-r from-gold-200 via-gold-400 to-gold-600">
          laske kultasi arvo
        </span>
      </h1>

      <p class="text-base md:text-lg text-gray-300 max-w-xl mx-auto mb-2 leading-relaxed">
        Syötä paino ja karaatit — näet heti <strong class="text-white font-medium">pörssikurssin mukaisen arvon</strong> sekä <strong class="text-white font-medium">vähimmäishinnan, jonka myydessä pitäisi saada</strong>.
      </p>
    </div>
  </div>

  <div id="laskuri" class="relative z-20 -mt-24 px-4 pb-12">
    <div class="max-w-5xl mx-auto reveal delay-200">
      
      <div class="bg-white rounded-[2rem] shadow-[0_25px_50px_-12px_rgba(0,0,0,0.25)] border border-gray-100 overflow-hidden p-1 md:p-2">
        {goldPrice ? (
          <GoldCalculator client:visible spotPriceEurPerGram={goldPrice.priceEurGram} />
        ) : (
          <div class="text-center p-12">
            <p class="text-red-500">Hintatietoja ei saatavilla.</p>
          </div>
        )}
      </div>

      <div class="mt-16">
        <div class="text-center mb-10">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-green-50 text-green-700 text-[10px] md:text-xs font-bold uppercase tracking-wide mb-4 border border-green-100 shadow-sm">
            <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
            Päivitetty automaattisesti
          </div>
          <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-4 tracking-tight">Arvioidut myyntihinnat</h2>
          <p class="text-gray-500 text-sm md:text-base max-w-2xl mx-auto leading-relaxed">
            Alla näet realistiset <strong class="text-gray-700">tavoitehinnat</strong> yleisimmille kultapitoisuuksille. 
            Hinnat edustavat reilua markkinahintaa, jota luotettavat ostajat maksavat.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 price-card-grid">
          {priceCards.map(card => (
            <PriceCard
              karat={card.karat}
              purity={card.purity}
              label={card.label}
              price={card.price}
              isHighlighted={card.isHighlighted}
            />
          ))}
        </div>
      </div>
    </div>
  </div>

  <section class="py-20 bg-white border-t border-gray-100">
    <div class="max-w-4xl mx-auto px-4">
      <JewelryWeightEstimator client:visible spotPrice={spot} />
    </div>
  </section>

  <section class="py-20 bg-gray-50 border-t border-gray-100">
    <div class="max-w-5xl mx-auto px-4 reveal">
      <div class="text-center mb-10">
        <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-4 tracking-tight">Kullan hintakehitys</h2>
        <p class="text-gray-500 text-sm md:text-base max-w-2xl mx-auto leading-relaxed mb-6">
          Seuraa kullan maailmanmarkkinahinnan kehitystä euroissa. Graafi päivittyy reaaliajassa.
        </p>
        <div class="inline-flex items-center gap-2 bg-white px-4 py-2 rounded-lg border border-gray-200 shadow-sm text-sm text-gray-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gold-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="16" x2="12" y2="12"></line>
            <line x1="12" y1="8" x2="12.01" y2="8"></line>
          </svg>
          Pörssissä hinta ilmoitetaan <strong>troy-unsseina</strong> (1 unssi = n. 31,1 grammaa).
        </div>
      </div>
      <div class="shadow-xl rounded-2xl overflow-hidden border border-gray-100">
         <GoldChart client:visible />
      </div>
    </div>
  </section>

  <section class="py-20 bg-white border-t border-gray-100">
    <div class="max-w-6xl mx-auto px-4 reveal">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-black text-gray-900 mb-4">Miksi kullan arvo kannattaa laskea?</h2>
        <p class="text-gray-500 max-w-2xl mx-auto text-lg">
          Kullan myynti on kannattavaa, kun tiedät esineidesi todellisen arvon. 
          Laskurimme auttaa sinua ymmärtämään, mistä hinta muodostuu, jotta osaat vaatia oikeaa hintaa.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 mb-12">
        {benefitCards.map(card => (
          <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 hover:border-gold-300 transition-all group">
            <div 
              class="w-14 h-14 bg-gold-50 rounded-2xl flex items-center justify-center text-3xl mb-6 group-hover:scale-110 transition-transform"
              role="img" 
              aria-label={card.iconLabel}
            >
              {card.icon}
            </div>
            <h3 class="font-bold text-gray-900 text-lg mb-3">{card.title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed" set:html={card.text} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="leimat" class="py-16 bg-gray-50 border-t border-gray-100">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        
        <div>
          <h2 class="text-3xl font-black text-gray-900 mb-6">Näin tunnistat arvokkaan kullan</h2>
          <div class="space-y-6 text-gray-600 leading-relaxed">
            <p>
              Kaikki keltainen ei ole kultaa. Ennen myyntiä on hyvä tarkistaa, 
              onko korusi aitoa jalometallia vai vain kullattua metallia. Tärkein tuntomerkki on leima.
            </p>
            
            <h3 class="text-xl font-bold text-gray-900 mt-8 mb-3">Tunnista kultaleimat (585, 750, 999)</h3>
            <p>
              Jalometallituotteissa on lähes aina leima, joka kertoo pitoisuuden. 
              Suomessa yleisin leima on <strong>585</strong>, mikä tarkoittaa 14 karaatin kultaa (58,5% puhdasta kultaa).
            </p>
            
            <ul class="space-y-3 mt-6">
              <li class="flex items-start gap-3">
                <span class="w-6 h-6 rounded-full bg-green-100 text-green-600 flex items-center justify-center shrink-0 mt-0.5">✓</span>
                <span><strong>Etsi leimat:</strong> Tarkista korun sisäpinta tai lukko suurennuslasilla. Aidoissa koruissa on lähes aina pitoisuusleima (esim. 585 tai 750).</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="w-6 h-6 rounded-full bg-green-100 text-green-600 flex items-center justify-center shrink-0 mt-0.5">✓</span>
                <span><strong>Magneettitesti:</strong> Aito kulta ei ole magneettista. Jos koru tarttuu napakasti magneettiin, se on todennäköisesti kullattua rautaa tai terästä.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="w-6 h-6 rounded-full bg-green-100 text-green-600 flex items-center justify-center shrink-0 mt-0.5">✓</span>
                <span><strong>Tarkista kulumat:</strong> Aito kulta on samanväristä myös pinnan alta. Jos naarmuista tai reunoista kuultaa läpi harmaa tai punertava metalli, esine on vain kullattu.</span>
              </li>
            </ul>

            <div class="mt-8 p-4 bg-gold-50/30 border border-gold-100/50 rounded-xl shadow-sm flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-white flex items-center justify-center shrink-0 shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gold-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-1 1.5-2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/>
                  <path d="M9 18h6"/>
                  <path d="M10 22h4"/>
                </svg>
              </div>
              <div>
                <h4 class="font-bold text-gray-900 text-sm">Vinkki: Puuttuuko suurennuslasi?</h4>
                <p class="text-sm text-gray-600 mt-1">
                  Voit kokeilla ottaa leimasta kuvan puhelimellasi hyvässä valossa. 
                  Kun zoomaat valmista kuvaa puhelimen näytöllä, näet pienetkin numerot usein yllättävän tarkasti.
                </p>
              </div>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-6">
          {stampCards.map(card => (
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 flex items-center gap-6 group hover:border-gold-300 transition-colors">
              <div class="w-16 h-16 bg-gold-50 rounded-full flex items-center justify-center text-gold-600 font-bold text-xl border border-gold-100 shrink-0">
                {card.purity}
              </div>
              <div>
                <h4 class="font-bold text-gray-900 text-lg">{card.karat}</h4>
                <p class="text-sm text-gray-500">{card.desc}</p>
              </div>
            </div>
          ))}
          <div class="mt-2">
            <a href="/kullan-leimat/" class="inline-flex items-center gap-1.5 text-gold-600 font-bold hover:underline text-sm">
              Lue täydellinen opas kullan leimoista →
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section id="ukk" class="py-20 bg-white border-t border-gray-100">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-3xl font-black text-center text-gray-900 mb-12">
        Usein kysyttyä kullan hinnasta
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {faqItems.map(item => (
          <FaqItem question={item.question} answer={item.answer} />
        ))}
      </div>
    </div>
  </section>

  <script>
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Reveal-animaatiot
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('active');
      });
    });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // --- Hintakorttien counter-animaatio ---
    if (!reducedMotion) {
      const priceObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          priceObserver.unobserve(entry.target);
          entry.target.querySelectorAll<HTMLElement>('.price-value').forEach(el => {
            const target = parseFloat(el.dataset.price ?? '');
            if (isNaN(target)) return;
            const duration = 900;
            const start = performance.now();
            function tick(now: number) {
              const t = Math.min((now - start) / duration, 1);
              const eased = 1 - Math.pow(1 - t, 3);
              el.textContent = (target * eased).toLocaleString('fi-FI', {
                minimumFractionDigits: 2, maximumFractionDigits: 2
              }) + ' €';
              if (t < 1) requestAnimationFrame(tick);
            }
            requestAnimationFrame(tick);
          });
        });
      }, { threshold: 0.3 });

      document.querySelectorAll('.price-card-grid').forEach(el => priceObserver.observe(el));
    }

    // --- Partikkelianimaatio ---
    (function () {
      const canvas = document.getElementById('hero-particles') as HTMLCanvasElement | null;
      if (!canvas || reducedMotion) return;
      const ctx = canvas.getContext('2d');
      if (!ctx) return;

      const COUNT = window.innerWidth < 768 ? 35 : 65;

      function resize() {
        canvas!.width = canvas!.offsetWidth;
        canvas!.height = canvas!.offsetHeight;
      }
      resize();
      window.addEventListener('resize', resize);

      type Particle = { x: number; y: number; r: number; vx: number; vy: number; alpha: number; alphaDir: number };
      const particles: Particle[] = Array.from({ length: COUNT }, () => ({
        x: Math.random() * canvas!.width,
        y: Math.random() * canvas!.height,
        r: Math.random() * 1.8 + 0.4,
        vx: (Math.random() - 0.5) * 0.25,
        vy: -(Math.random() * 0.35 + 0.08),
        alpha: Math.random() * 0.5 + 0.1,
        alphaDir: (Math.random() - 0.5) * 0.004,
      }));

      function draw() {
        ctx!.clearRect(0, 0, canvas!.width, canvas!.height);
        for (const p of particles) {
          p.x += p.vx;
          p.y += p.vy;
          p.alpha += p.alphaDir;
          if (p.alpha <= 0.05) p.alphaDir = Math.abs(p.alphaDir);
          if (p.alpha >= 0.65) p.alphaDir = -Math.abs(p.alphaDir);
          if (p.y < -4) { p.y = canvas!.height + 4; p.x = Math.random() * canvas!.width; }
          if (p.x < -4) p.x = canvas!.width + 4;
          if (p.x > canvas!.width + 4) p.x = -4;
          ctx!.beginPath();
          ctx!.arc(p.x, p.y, p.r, 0, Math.PI * 2);
          ctx!.fillStyle = `rgba(212,175,55,${p.alpha.toFixed(3)})`;
          ctx!.fill();
        }
        requestAnimationFrame(draw);
      }
      draw();
    })();

    // --- Hintanumeron counter-animaatio ---
    (function () {
      const el = document.getElementById('hero-spot-price');
      if (!el || reducedMotion) return;
      const target = parseFloat((el as HTMLElement).dataset.target ?? '');
      if (isNaN(target) || target <= 0) return;
      const duration = 1800;
      const start = performance.now();
      el.textContent = '0.00';
      function tick(now: number) {
        const t = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - t, 4);
        el!.textContent = (target * eased).toFixed(2);
        if (t < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    })();
  </script>

</BaseLayout>