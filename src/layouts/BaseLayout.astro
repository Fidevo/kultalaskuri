---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  canonical,
  schema,
  ogImage = '/kultalaskuri-logo.png',
  noindex = false
} = Astro.props;


const siteUrl = 'https://kultalaskuri.fi';
const defaultCanonical = new URL(Astro.url.pathname, siteUrl).toString();
const finalCanonical = canonical || defaultCanonical;
// og:image vaatii absoluuttisen URL:n — Astro-assetit tulevat suhteellisina (/_astro/...)
const ogImageAbs = new URL(ogImage, siteUrl).toString();

const siteName = 'Kultalaskuri.fi';
const isProd = import.meta.env.PROD;
---

<!DOCTYPE html>
<html lang="fi" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <link rel="canonical" href={finalCanonical} />
    <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow, max-image-preview:large, max-snippet:-1'} />
    
    <meta name="google-site-verification" content="X9EntxvR0l_Tx3Uj-Zy_rr89c-c_hqQpcMNEuIW6mBA" />
    
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={finalCanonical} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="fi_FI" />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:image:alt" content="Kultalaskuri.fi – Laske kultasi arvo" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />
    
    {schema && <script type="application/ld+json" set:html={schema} />}
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/icon-512.png" />
    <link rel="apple-touch-icon" href="/icon-512.png" />
    
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0B0F19" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link 
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" 
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link 
        href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" 
        rel="stylesheet"
      />
    </noscript>

    {/* Umami Analytics — evästeetön, GDPR-yhteensopiva */}
    {isProd && (
      <script
        defer
        src="https://cloud.umami.is/script.js"
        data-website-id="3a8f18bb-92f1-43ba-b173-43e1f64776bd"
      />
    )}

    {/* Microsoft Clarity — session recording & heatmapit */}
    {isProd && (
      <script type="text/javascript" is:inline>
        (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, "clarity", "script", "wafdvf8nrk");
      </script>
    )}
  </head>
  
  <body class="min-h-screen flex flex-col bg-gray-50 text-gray-900 font-sans antialiased selection:bg-gold-400 selection:text-[#0B0F19]">
    <Header />
    
    <main class="flex-grow w-full relative z-10">
      <slot />
    </main>
    
    <Footer />

    <button
      id="pwa-install"
      class="hidden fixed bottom-6 left-6 z-50 items-center gap-2 px-4 py-3 bg-[#131b2e] text-white
        text-sm font-bold rounded-xl border border-gold-400/30 shadow-lg no-print"
    >
      <svg class="w-4 h-4 text-gold-400 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect width="14" height="20" x="5" y="2" rx="2"/><path d="M12 18h.01"/><path d="M12 7v5"/><path d="m9.5 9.5 2.5 2.5 2.5-2.5"/></svg>
      <span>Lisää kotinäytölle</span>
    </button>

    <button
      id="global-scroll-to-top"
      class="fixed bottom-6 right-6 z-50 p-4 bg-gradient-to-r from-gold-400 to-gold-600
        text-[#0B0F19] rounded-full shadow-lg shadow-gold-400/20 opacity-0 translate-y-10
        transition-all duration-300 hover:scale-110 pointer-events-none"
      aria-label="Palaa ylös"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 10l7-7m0 0l7 7m-7-7v18" />
      </svg>
    </button>

    <script>
      const track = (event: string, data?: Record<string, string | number>) => {
        try {
          const umami = (window as any).umami;
          if (umami?.track) {
            umami.track(event, data);
          } else {
            window.setTimeout(() => {
              try { (window as any).umami?.track(event, data); } catch {}
            }, 1200);
          }
        } catch {}
      };

      // 1. Yhdistetty scroll-kuuntelija: scroll-to-top -nappi + Umami scroll-syvyys
      const globalScrollBtn = document.getElementById('global-scroll-to-top');
      const scrollThresholds = [25, 50, 75, 100];
      const firedDepths = new Set<number>();

      function onGlobalScroll() {
        // Scroll-to-top -näkyvyys
        if (window.scrollY > 400) {
          globalScrollBtn?.classList.remove('opacity-0', 'translate-y-10', 'pointer-events-none');
        } else {
          globalScrollBtn?.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
        }

        // Umami: scroll-syvyys
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        if (docHeight > 0) {
          const pct = Math.round((window.scrollY / docHeight) * 100);
          for (const t of scrollThresholds) {
            if (pct >= t && !firedDepths.has(t)) {
              firedDepths.add(t);
              track('scroll-depth', { depth: t });
            }
          }
        }
      }

      let scrollTicking = false;
      window.addEventListener('scroll', () => {
        if (!scrollTicking) {
          window.requestAnimationFrame(() => {
            onGlobalScroll();
            scrollTicking = false;
          });
          scrollTicking = true;
        }
      }, { passive: true });

      globalScrollBtn?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });

      // --- PWA: asennuskehote (manifest on jo olemassa) ---
      (function () {
        const installBtn = document.getElementById('pwa-install');
        let deferredPrompt: any = null;
        const isStandalone =
          window.matchMedia('(display-mode: standalone)').matches ||
          (window.navigator as any).standalone === true;

        if (isStandalone && !sessionStorage.getItem('kl-pwa-open-tracked')) {
          sessionStorage.setItem('kl-pwa-open-tracked', '1');
          track('pwa-open', { path: window.location.pathname });
        }

        window.addEventListener('appinstalled', () => {
          localStorage.setItem('kl-pwa-installed', '1');
          track('pwa-installed');
        });

        window.addEventListener('beforeinstallprompt', (e) => {
          e.preventDefault();
          deferredPrompt = e;
          track('pwa-install-available');
          if (localStorage.getItem('kl-pwa-dismissed')) return;
          installBtn?.classList.remove('hidden');
          installBtn?.classList.add('flex');
        });

        installBtn?.addEventListener('click', async () => {
          installBtn.classList.add('hidden');
          installBtn.classList.remove('flex');
          if (!deferredPrompt) return;
          track('pwa-install-prompt');
          deferredPrompt.prompt();
          const choice = await deferredPrompt.userChoice;
          if (choice?.outcome === 'accepted') {
            track('pwa-install-accepted');
          } else {
            track('pwa-install-dismissed');
            localStorage.setItem('kl-pwa-dismissed', '1');
          }
          deferredPrompt = null;
        });
      })();

      // --- Umami: CTA-linkkien seuranta ---
      document.querySelectorAll('a[href*="#laskuri"], a[href*="#myyntilaskuri"]').forEach(el => {
        el.addEventListener('click', () => {
          track('cta-click', { href: (el as HTMLAnchorElement).href, text: (el as HTMLElement).textContent?.trim().slice(0, 50) || '' });
        });
      });

      // --- Umami: päävalikon ja footerin linkit ---
      document.querySelectorAll('header a[href], footer a[href]').forEach(el => {
        el.addEventListener('click', () => {
          const link = el as HTMLAnchorElement;
          const area = link.closest('header') ? 'header' : 'footer';
          track('nav-click', {
            area,
            href: link.getAttribute('href') || '',
            text: link.textContent?.trim().replace(/\s+/g, ' ').slice(0, 60) || '',
          });
        });
      });

      // FAQ: auki desktopilla, kiinni mobiilissa. Synkataan vain latauksessa ja
      // kun breakpoint oikeasti ylittyy — ei jokaisella resizellä (mobiiliselainten
      // osoitepalkin piiloutuminen laukaisee resizen ja sulkisi käyttäjän avaaman FAQ:n).
      const faqMql = window.matchMedia('(min-width: 768px)');

      function syncFaqState(isDesktop: boolean) {
        document.querySelectorAll('#ukk details').forEach(d => {
          if (isDesktop) {
            d.setAttribute('open', '');
          } else {
            d.removeAttribute('open');
          }
        });
      }

      syncFaqState(faqMql.matches);
      faqMql.addEventListener('change', (e) => syncFaqState(e.matches));
    </script>
  </body>
</html>
