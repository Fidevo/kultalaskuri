---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: string;
  ogImage?: string;
}

const { 
  title, 
  description, 
  canonical,
  schema,
  ogImage = 'https://kultalaskuri.fi/kultalaskuri-logo.png' 
} = Astro.props;


const siteUrl = 'https://kultalaskuri.fi';
const defaultCanonical = new URL(Astro.url.pathname, siteUrl).toString();
const finalCanonical = canonical || defaultCanonical;

const siteName = 'Kultalaskuri.fi';
const isProd = import.meta.env.PROD;
---

<!DOCTYPE html>
<html lang="fi" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <link rel="canonical" href={finalCanonical} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    
    <meta name="google-site-verification" content="X9EntxvR0l_Tx3Uj-Zy_rr89c-c_hqQpcMNEuIW6mBA" />
    
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={finalCanonical} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="fi_FI" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="Kultalaskuri.fi – Laske kultasi arvo" />
    
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    
    {schema && <script type="application/ld+json" set:html={schema} />}
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/kultalaskuri-logo.png" />
    <link rel="apple-touch-icon" href="/kultalaskuri-logo.png" />
    
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0B0F19" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link 
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" 
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link 
        href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" 
        rel="stylesheet"
      />
    </noscript>

    {/* Umami Analytics — evästeetön, GDPR-yhteensopiva */}
    {isProd && (
      <script 
        defer 
        src="https://cloud.umami.is/script.js" 
        data-website-id="3a8f18bb-92f1-43ba-b173-43e1f64776bd"
      />
    )}
  </head>
  
  <body class="min-h-screen flex flex-col bg-gray-50 text-gray-900 font-sans antialiased selection:bg-gold-400 selection:text-[#0B0F19]">
    <Header />
    
    <main class="flex-grow w-full relative z-10">
      <slot />
    </main>
    
    <Footer />

    <button 
      id="global-scroll-to-top" 
      class="fixed bottom-6 right-6 z-50 p-4 bg-gradient-to-r from-gold-400 to-gold-600 
        text-[#0B0F19] rounded-full shadow-lg shadow-gold-400/20 opacity-0 translate-y-10 
        transition-all duration-300 hover:scale-110 focus:outline-none pointer-events-none"
      aria-label="Palaa ylös"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 10l7-7m0 0l7 7m-7-7v18" />
      </svg>
    </button>

    <script>
      // 1. Scroll-to-top -logiikka
      const globalScrollBtn = document.getElementById('global-scroll-to-top');

      function handleGlobalScroll() {
        if (window.scrollY > 400) {
          globalScrollBtn?.classList.remove('opacity-0', 'translate-y-10', 'pointer-events-none');
        } else {
          globalScrollBtn?.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
        }
      }

      let isScrolling = false;
      window.addEventListener('scroll', () => {
        if (!isScrolling) {
          window.requestAnimationFrame(() => {
            handleGlobalScroll();
            isScrolling = false;
          });
          isScrolling = true;
        }
      });

      globalScrollBtn?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });

      
      // --- Umami: scroll-syvyys ---
      (function () {
        const thresholds = [25, 50, 75, 100];
        const fired = new Set<number>();
        function onScroll() {
          const scrollTop = window.scrollY;
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          if (docHeight <= 0) return;
          const pct = Math.round((scrollTop / docHeight) * 100);
          for (const t of thresholds) {
            if (pct >= t && !fired.has(t)) {
              fired.add(t);
              try { (window as any).umami?.track('scroll-depth', { depth: t }); } catch {}
            }
          }
        }
        let ticking = false;
        window.addEventListener('scroll', () => {
          if (!ticking) {
            window.requestAnimationFrame(() => { onScroll(); ticking = false; });
            ticking = true;
          }
        });
      })();

      // --- Umami: CTA-linkkien seuranta ---
      document.querySelectorAll('a[href*="#laskuri"], a[href*="#myyntilaskuri"]').forEach(el => {
        el.addEventListener('click', () => {
          try { (window as any).umami?.track('cta-click', { href: (el as HTMLAnchorElement).href, text: (el as HTMLElement).textContent?.trim().slice(0, 50) || '' }); } catch {}
        });
      });

      function syncFaqState() {
        const isDesktop = window.matchMedia('(min-width: 768px)').matches;
        document.querySelectorAll('#ukk details').forEach(d => {
          if (isDesktop) {
            d.setAttribute('open', '');
          } else {
            d.removeAttribute('open');
          }
        });
      }
      
      
      syncFaqState();
      
      
      let resizeTimer = 0;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = window.setTimeout(syncFaqState, 150);
      });
    </script>
  </body>
</html>