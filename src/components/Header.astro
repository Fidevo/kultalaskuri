---
const pathname = Astro.url.pathname;
const normalizedPath = pathname.endsWith('/') && pathname.length > 1 ? pathname.slice(0, -1) : pathname;

const navLinks = [
  { href: '/#laskuri', label: 'Laskuri', pagePath: '/' },
  { href: '/kullan-myynti/', label: 'Kullan myynti', pagePath: '/kullan-myynti' }, // Kauttaviiva lisätty hrefiin
  { href: '/kullan-leimat/', label: 'Kultaleimat', pagePath: '/kullan-leimat' }, // Kauttaviiva lisätty hrefiin
];
---

<header id="main-header" class="fixed top-0 w-full z-50 bg-[#0B0F19]/95 backdrop-blur-md border-b border-white/5 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      
      <a href="/" class="flex flex-col group relative z-50" aria-label="Palaa alkuun">
        <span class="text-2xl font-black tracking-tight leading-none transition-colors">
          <span class="text-gold-400">Kulta</span><span class="text-white">laskuri</span><span class="text-gold-400">.fi</span>
        </span>
        <span class="text-[10px] text-gray-400 uppercase tracking-[0.2em] leading-none mt-1 ml-0.5 group-hover:text-gold-200 transition-colors">
          Luotettava arvio
        </span>
      </a>

      <nav class="hidden md:flex items-center gap-8">
        {navLinks.map((link) => {
          // Tarkistetaan onko linkki sama kuin nykyinen sivu
          const isActive = normalizedPath === link.pagePath;
          
          return (
            <a 
              href={link.href}
              aria-current={isActive ? "page" : undefined}
              class={`text-sm font-bold transition-all duration-200 relative py-2 uppercase tracking-wide
                ${isActive ? 'text-gold-400' : 'text-gray-400 hover:text-gold-400'}
              `}
            >
              {link.label}
            </a>
          );
        })}
      </nav>

      <div class="flex items-center gap-4 md:hidden">
        <button 
          id="mobile-menu-btn"
          class="relative z-50 p-2 text-gray-400 hover:text-white transition-colors focus:outline-none"
          aria-label="Avaa valikko"
          aria-expanded="false"
        >
          <svg id="menu-icon" class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="close-icon" class="w-8 h-8 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div 
    id="mobile-menu" 
    class="fixed inset-0 z-40 bg-[#0B0F19] w-full h-screen transform translate-x-full transition-transform duration-300 md:hidden flex flex-col pt-28 px-8"
  >
    <div class="flex flex-col space-y-6">
      {navLinks.map((link) => {
        const isActive = normalizedPath === link.pagePath;
        
        return (
          <a 
            href={link.href}
            aria-current={isActive ? "page" : undefined}
            class={`mobile-link text-2xl font-bold border-b border-white/5 pb-4 
              ${isActive ? 'text-gold-400' : 'text-white hover:text-gold-400'}
            `}
          >
            {link.label}
          </a>
        );
      })}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');
  const mobileLinks = document.querySelectorAll('.mobile-link');
  
  let isMenuOpen = false;

  function toggleMenu() {
    isMenuOpen = !isMenuOpen;
    
    if (btn) {
      btn.setAttribute('aria-expanded', String(isMenuOpen));
      btn.setAttribute('aria-label', isMenuOpen ? 'Sulje valikko' : 'Avaa valikko');
    }
    
    if (isMenuOpen) {
      // Avaa
      menu?.classList.remove('translate-x-full');
      document.body.style.overflow = 'hidden'; // Estä taustan skrollaus
      menuIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
    } else {
      // Sulje
      menu?.classList.add('translate-x-full');
      document.body.style.overflow = ''; // Salli skrollaus
      menuIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    }
  }
  
  btn?.addEventListener('click', toggleMenu);
  
  mobileLinks.forEach(link => {
    link.addEventListener('click', () => {
      if (isMenuOpen) toggleMenu();
    });
  });
</script>